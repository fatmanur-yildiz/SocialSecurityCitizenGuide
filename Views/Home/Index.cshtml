@{
    ViewData["Title"] = "Ana Sayfa";
}

<section style="min-height: 520px; display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 70px 0 70px 7%; background: linear-gradient(90deg, #f8fafc 0%, #f8fafc 58%, #eef6ff 100%); border-bottom: 1px solid #dbeafe; overflow: hidden;">
    <div style="max-width: 720px; flex: 1;">
        <span class="official-badge">Sosyal Güvenlik Kurumu Bilgilendirme Sistemi</span>

        <h1 style="margin: 24px 0 22px; color: #111827; font-size: 52px; line-height: 1.14; font-weight: 800; letter-spacing: -0.8px;">
            Sosyal Güvenlik Bilgilerinize Yönelik Ön Bilgilendirme ve Rehberlik Hizmeti
        </h1>

        <p style="max-width: 680px; margin: 0; color: #334155; font-size: 21px; line-height: 1.55;">
            Prim bilgileri, emeklilik durumu, borçlanma işlemleri ve hizmet birleştirme süreçlerine ilişkin kullanıcı odaklı bilgilendirme sunar.
        </p>

        <div class="hero-actions" style="margin-top: 32px;">
            <a class="btn-primary-custom" href="/Account/Login">Giriş Yap</a>
            <a class="btn-outline-custom" href="/Account/Register">Kayıt Ol</a>
        </div>
    </div>

   <div style="width: 760px; max-width: 50%; height: 390px; overflow: hidden; display: flex; align-items: center; justify-content: flex-end; position: relative;">
    <img src="/images/sgk-hero.png"
         alt="Sosyal güvenlik rehberi görseli"
         style="width: 100%; height: 100%; object-fit: cover; object-position: right center; display: block;" />

    <div style="position: absolute; inset: 0; background: linear-gradient(90deg, #f8fafc 0%, rgba(248, 250, 252, 0.92) 18%, rgba(248, 250, 252, 0.45) 38%, rgba(248, 250, 252, 0) 65%); pointer-events: none;"></div>
</div>
</section>

<section class="services-section">
    <h2>Vatandaş Hizmetleri</h2>
    <p class="section-desc">İşlem yapmak istediğiniz alanı seçerek ilgili bilgilendirme sayfasına ulaşabilirsiniz.</p>

    <div class="service-grid">
        <a class="service-card" href="/Account/Login">
            <h3>Prim Analizi</h3>
            <p>Toplam prim günü, son bildirilen dönem, eksik gün durumu ve prime esas kazanç bilgileri gösterilir.</p>
        </a>

        <a class="service-card" href="/Account/Login">
            <h3>Emeklilik Durumu</h3>
            <p>Yüklenen belge ve kullanıcı bilgileri doğrultusunda emeklilik sürecine ilişkin bilgilendirme sunulur.</p>
        </a>

        <a class="service-card" href="/Account/Login">
            <h3>Borçlanma İşlemleri</h3>
            <p>Doğum, askerlik ve yurt dışı borçlanması gibi süreçler hakkında genel bilgilendirme ve hesaplama desteği sağlanır.</p>
        </a>

        <a class="service-card" href="/Account/Login">
            <h3>Hizmet Birleştirme</h3>
            <p>Farklı sigorta statülerindeki hizmet süreleri hakkında ön bilgilendirme ve yönlendirme sunulur.</p>
        </a>

        <a class="service-card" href="/Citizen/Faq">
            <h3>Sık Sorulan Sorular</h3>SGK terimleri ve vatandaşların sık karşılaştığı konular hakkında açıklamalara ulaşılabilir.</p>
        </a>
        <a class="service-card" href="/Account/Login">
            <h3>Resmi SGK/e-Devlet İşlemleri</h3>
            <p>Kesin başvuru, doğrulama ve resmi işlem gerektiren durumlar için ilgili SGK ve e-Devlet hizmetlerine yönlendirme sağlanır.</p>
        </a>
    </div>
</section>