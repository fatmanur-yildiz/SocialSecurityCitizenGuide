@model EmekliRehberi.ViewModels.RetirementInputViewModel
@using EmekliRehberi.Models
@using EmekliRehberi.Services
@using System.Linq
@using System.Globalization

@{
    ViewData["Title"]      = "Emeklilik Durumu";
    ViewData["ActivePage"] = "RetirementStatus";

    var premium   = ViewBag.LatestPremium as PremiumDocument;
    var socialSec = ViewBag.LatestSocialSecurity as SocialSecurityRecordDocument;
    var manual    = ViewBag.ManualInput as EmekliRehberi.ViewModels.RetirementInputViewModel;

    var monthlyRecords = premium?.Records?
        .Where(r => !r.IsYearTotal)
        .OrderBy(r => r.Period)
        .ToList() ?? new List<PremiumRecord>();

    var pekRecords = monthlyRecords.Where(r => r.PekAmount.HasValue).ToList();
    decimal? avgPek  = pekRecords.Any() ? pekRecords.Average(r => r.PekAmount!.Value) : null;
    decimal? lastPek = pekRecords.Any() ? pekRecords.OrderByDescending(r => r.Period).First().PekAmount : null;

    // İlk sigorta tarihi — InsuranceDateResolver (Aşama 1)
    var resolved        = ViewBag.ResolvedInsuranceDate as InsuranceDateResolver.ResolvedInsuranceDate;
    DateTime? firstDate = resolved?.Date;
    string firstDateSource = resolved?.Source ?? "";

    double? insuranceYears = firstDate.HasValue
        ? (DateTime.Now - firstDate.Value).TotalDays / 365.25
        : null;

    int totalDays = premium?.TotalPremiumDays ?? socialSec?.TotalDays ?? 0;

    int? age = manual?.BirthDate.HasValue == true
        ? (int)((DateTime.Now - manual.BirthDate!.Value).TotalDays / 365.25)
        : null;

    int days4A = socialSec?.Days4A ?? 0;
    int days4B = socialSec?.Days4B ?? 0;
    int days4C = socialSec?.Days4C ?? 0;
    int nonZeroStatuses = (days4A > 0 ? 1 : 0) + (days4B > 0 ? 1 : 0) + (days4C > 0 ? 1 : 0);
    bool multipleStatuses = nonZeroStatuses > 1;

    string dominantStatus = "Belirsiz";
    if (socialSec != null)
    {
        if      (days4A > 0 && days4B == 0 && days4C == 0) dominantStatus = "4A (SSK)";
        else if (days4B > 0 && days4A == 0 && days4C == 0) dominantStatus = "4B (Bağ-Kur)";
        else if (days4C > 0 && days4A == 0 && days4B == 0) dominantStatus = "4C (Emekli Sandığı)";
        else if (multipleStatuses)
            dominantStatus = days4A >= days4B && days4A >= days4C ? "4A ağırlıklı" :
                             days4B >= days4A && days4B >= days4C ? "4B ağırlıklı" : "4C ağırlıklı";
    }
    else if (!string.IsNullOrWhiteSpace(manual?.TargetStatus) && manual?.TargetStatus != "Bilmiyorum")
    {
        dominantStatus = manual!.TargetStatus!;
    }

    bool hasPremiumDoc   = premium != null;
    bool hasSocialSecDoc = socialSec != null;
    bool hasBirthDate    = manual?.BirthDate.HasValue == true;
    bool hasGender       = !string.IsNullOrWhiteSpace(manual?.Gender);
    bool hasFirstDate    = firstDate.HasValue;
    bool hasStatusFromDoc = socialSec != null && (days4A + days4B + days4C) > 0;
    bool hasStatusManual  = !string.IsNullOrWhiteSpace(manual?.TargetStatus) && manual?.TargetStatus != "Bilmiyorum";
    bool hasStatus        = hasStatusFromDoc || hasStatusManual;
    bool formSubmitted    = manual != null;
    bool isFemale = manual?.Gender == "Kadın";
    bool isMale   = manual?.Gender == "Erkek";
    var trCulture = new CultureInfo("tr-TR");

    // EYT sınır tarihi
    var eytCutoff = new DateTime(1999, 9, 8);
    bool? isEytScope = firstDate.HasValue ? firstDate.Value <= eytCutoff : (bool?)null;

    // Hangi statü dominantsa ona göre önerilen araç grubu
    string statusGroup = dominantStatus.StartsWith("4A") ? "4A"
                       : dominantStatus.StartsWith("4B") ? "4B"
                       : dominantStatus.StartsWith("4C") ? "4C"
                       : "Belirsiz";
}

<section class="dashboard-page">
    @await Html.PartialAsync("_CitizenSidebar")

    <main class="dashboard-content">

        @* ─── Sayfa başlığı ve bölüm navigasyonu ──────────────────────── *@
        <div class="page-title" style="margin-bottom:12px;">
            <h1>Emeklilik Durumu</h1>
            <p>Belgelerinize göre kısa ön değerlendirme. Kesin sonuç için SGK/e-Devlet araçlarına yönlendirilirsiniz.</p>
        </div>

        <nav class="section-nav" aria-label="Sayfa bölümleri">
            <a href="#genel-bilgi">Genel Bilgi</a>
            <a href="#pdf-analiz">PDF Analizi ve SGK Yönlendirmesi</a>
        </nav>

        @* ════════════════════════════════════════════════════════════════
           BÖLÜM 1 — GENEL BİLGİ
        ════════════════════════════════════════════════════════════════ *@
        <section id="genel-bilgi" class="rs-section">
            <div class="rs-section-header">
                <span class="rs-section-icon">📖</span>
                <h2>Genel Bilgi</h2>
            </div>

            <p style="color:#6b7280;font-size:14px;line-height:1.7;margin:0 0 18px;">
                Emeklilik sürecinde sık karşılaşılan temel kavramları sade biçimde inceleyebilirsiniz.
                Bu bölüm bilgilendirme amaçlıdır; kişiye özel kesin hesaplamalar için SGK'nın resmi araçları kullanılmalıdır.
            </p>

            @{
                const string sgkGenelLink = "https://www.sgk.gov.tr/Content/Post/24a62093-24ca-4a18-81e1-f79300b94a49/Emekli-Kavrami-2022-05-15-05-12-26";
            }

            <div class="info-cards-grid">

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">🧓</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Emeklilik Nedir?</span>
                            <span class="info-card-short">Çalışma hayatından aylık alma dönemine geçişi ifade eder.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Emeklilik, kişinin çalışma hayatı boyunca bildirilen primleri ve sigortalılık bilgileri üzerinden belirli şartları sağlaması halinde aylık alabilmesidir.</p>
                        <p>Bu süreç yalnızca "kaç gün primim var?" sorusuyla açıklanamaz. İlk sigorta başlangıcı, yaş, sigorta statüsü ve prim günü birlikte değerlendirilir.</p>
                        <p>Bu kart temel bilgilendirme içindir; kişiye özel hesaplama PDF Analizi bölümünde yapılır.</p>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">🏦</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Yaşlılık Aylığı</span>
                            <span class="info-card-short">Emeklilik şartları sağlandığında bağlanan aylıktır.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Yaşlılık aylığı, sigortalının yaş, prim günü ve sigortalılık süresi gibi şartları sağlaması halinde bağlanabilen emeklilik aylığıdır.</p>
                        <p>Hangi şartların aranacağı kişinin ilk sigorta başlangıcına ve 4A, 4B, 4C statüsüne göre değişebilir.</p>
                        <p>Bu nedenle sistem kesin aylık bağlama kararı vermez; sadece belgeler üzerinden ön değerlendirme yapar.</p>
                        <a href="@sgkGenelLink" target="_blank" rel="noopener noreferrer" class="info-card-btn">Detaylı Bilgi →</a>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">⏳</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Sigortalılık Süresi</span>
                            <span class="info-card-short">İlk sigorta başlangıcından emeklilik talebine kadar geçen süredir.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Sigortalılık süresi, kişinin ilk defa uzun vadeli sigorta kapsamında çalışmaya başladığı tarihten emeklilik talebine kadar geçen süreyi ifade eder.</p>
                        <p>Bu nedenle ilk sigorta başlangıcının doğru belirlenmesi önemlidir. Sosyal Güvenlik Kayıt Belgesi ile Hizmet Dökümü farklı tarih gösterebilir.</p>
                        <p>Sistem, mümkünse hizmet dökümündeki en eski işe giriş tarihini dikkate alır.</p>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">📋</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Prim Ödeme Gün Sayısı</span>
                            <span class="info-card-short">SGK'ya bildirilen emeklilik hesabına esas gün sayısıdır.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Prim ödeme gün sayısı, sigortalı adına SGK'ya bildirilen uzun vadeli sigorta günlerini ifade eder.</p>
                        <p>Emeklilik değerlendirmesinde temel bilgilerden biridir; ancak tek başına yeterli değildir.</p>
                        <p>Prim günü, yaş, sigorta başlangıcı ve statü bilgisiyle birlikte değerlendirilir.</p>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">🎂</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Yaş Koşulu</span>
                            <span class="info-card-short">Emeklilik için gerekli yaş şartı kişiye göre değişebilir.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Yaş şartı; sigorta başlangıç tarihi, çalışma statüsü ve kişinin durumuna göre değişebilir.</p>
                        <p>Aynı prim gününe sahip iki kişinin emeklilik şartları farklı olabilir.</p>
                        <p>Bu nedenle sistem yaş için ön değerlendirme yapar, kesin hesaplama için SGK'nın resmi araçlarına yönlendirir.</p>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">🏷️</span>
                        <span class="info-card-text">
                            <span class="info-card-title">4A, 4B ve 4C Nedir?</span>
                            <span class="info-card-short">Çalışma şekline göre farklı sigorta statüleridir.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>4A genellikle hizmet akdiyle çalışanları, 4B kendi adına bağımsız çalışanları, 4C ise kamu görevlilerini ifade eder.</p>
                        <p>Kişinin farklı statülerde çalışması varsa, hangi statüden emekli olunacağı ayrıca önem kazanabilir.</p>
                        <p>Bu durumda Hizmet Birleştirme sayfasında statü dağılımı ayrıca kontrol edilmelidir.</p>
                        <a href="/Citizen/ServiceMerge" class="info-card-btn info-card-btn--internal">Hizmet Birleştirme'ye Git →</a>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">📅</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Ne Zaman Emekli Olabilirim?</span>
                            <span class="info-card-short">Kesin hesaplama için SGK'nın resmi araçları kullanılmalıdır.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Bu sistem yüklenen belgelerden başlangıç tarihi, prim günü, statü ve bazı temel bilgileri okuyarak ön değerlendirme yapar.</p>
                        <p>Ancak kesin emeklilik zamanı; kişinin tüm SGK kayıtları, özel durumları, borçlanmaları ve güncel mevzuatla birlikte değerlendirilir.</p>
                        <p>Bu nedenle kesin sonuç için SGK'nın resmi "Ne Zaman Emekli Olabilirim?" araçlarına yönlendirme yapılır.</p>
                        <a href="#pdf-analiz" class="info-card-btn info-card-btn--internal">Resmi Hesaplama Araçlarına Git →</a>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">💰</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Emekli Aylığı Hesaplanabilir mi?</span>
                            <span class="info-card-short">Net emekli aylığı bu belgelerle kesin hesaplanamaz.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Emekli aylığı hesabında prime esas kazanç, çalışma dönemleri, aylık bağlama oranları ve SGK'nın hesaplama kuralları birlikte değerlendirilir.</p>
                        <p>Hizmet dökümündeki PEK bilgisi bu konuda fikir verir; ancak tek başına net maaş sonucu üretmez.</p>
                        <p>Bu nedenle sistem maaş tahmini yapmaz, resmi SGK/e-Devlet hesaplama araçlarına yönlendirir.</p>
                        <a href="#pdf-analiz" class="info-card-btn info-card-btn--internal">SGK Hesaplama Araçlarına Git →</a>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">💼</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Emeklilikten Sonra Çalışma</span>
                            <span class="info-card-short">Emeklilik sonrası çalışma kuralları başlangıç tarihi ve statüye göre değişebilir.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Emekli olduktan sonra çalışmaya devam edilmesi halinde aylığın kesilip kesilmeyeceği veya sosyal güvenlik destek primi uygulanıp uygulanmayacağı kişinin durumuna göre değişebilir.</p>
                        <p>İlk sigorta başlangıcı, emekli olunan statü ve yeniden çalışılacak statü bu değerlendirmede önemlidir.</p>
                        <p>Bu konu ayrıntılı mevzuat gerektirdiği için sistem yalnızca genel bilgilendirme yapar, kesin karar üretmez.</p>
                        <a href="@sgkGenelLink" target="_blank" rel="noopener noreferrer" class="info-card-btn">Detaylı Bilgi →</a>
                    </div>
                </details>

                <details class="info-card">
                    <summary class="info-card-summary">
                        <span class="info-card-icon">🔄</span>
                        <span class="info-card-text">
                            <span class="info-card-title">Toptan Ödeme ve İhya</span>
                            <span class="info-card-short">Aylık bağlanamayan bazı durumlarda prim iadesi veya ihya gündeme gelebilir.</span>
                        </span>
                        <span class="info-card-chevron">▾</span>
                    </summary>
                    <div class="info-card-detail">
                        <p>Bazı sigortalılar yaş şartını doldurduğu halde aylık bağlanması için gerekli prim veya süre şartlarını sağlayamayabilir.</p>
                        <p>Bu tür durumlarda toptan ödeme veya daha önce tasfiye edilen hizmetlerin yeniden ihyası gibi işlemler gündeme gelebilir.</p>
                        <p>Bu konu kişiye özel olduğu için yalnızca genel bilgi verilir; kesin değerlendirme için SGK kaynağına bakılmalıdır.</p>
                        <a href="@sgkGenelLink" target="_blank" rel="noopener noreferrer" class="info-card-btn">Detaylı Bilgi →</a>
                    </div>
                </details>

            </div>

            <p style="color:#9ca3af;font-size:12px;margin:14px 0 0;">
                Diğer temel kavramlar için SGK'nın genel emeklilik bilgi sayfasını da inceleyebilirsiniz:
                <a href="@sgkGenelLink" target="_blank" rel="noopener noreferrer" style="color:#005BAC;font-weight:700;">SGK — Emekli Kavramı →</a>
            </p>
        </section>

        @* ════════════════════════════════════════════════════════════════
           BÖLÜM 2 — PDF ANALİZİ VE SGK YÖNLENDİRMESİ
        ════════════════════════════════════════════════════════════════ *@
        <section id="pdf-analiz" class="rs-section">
            <div class="rs-section-header">
                <span class="rs-section-icon">📊</span>
                <h2>PDF Analizi ve SGK Yönlendirmesi</h2>
            </div>

            @* Veri kaynakları *@
            <div class="premium-detail-card" style="margin-bottom:20px;">
                <h2>Kullanılan Veri Kaynakları</h2>
                <div class="veri-kaynak-grid">
                    <div class="veri-kaynak-item @(hasPremiumDoc ? "kaynak-var" : "kaynak-yok")">
                        <div class="kaynak-baslik">SGK Tescil ve Hizmet Dökümü</div>
                        <div class="kaynak-durum">
                            @if (hasPremiumDoc)
                            {
                                <span style="color:#15803d;">&#10003; Yüklendi — @premium!.CreatedAt.ToString("dd.MM.yyyy")</span>
                            }
                            else
                            {
                                <span style="color:#b45309;">&#9888; Yüklenmedi</span>
                                <a href="/Citizen/PremiumInfo" style="display:block;margin-top:6px;color:#005BAC;font-weight:700;font-size:13px;">
                                    Prim Bilgilerim sayfasından yükleyin →
                                </a>
                            }
                        </div>
                    </div>
                    <div class="veri-kaynak-item @(hasSocialSecDoc ? "kaynak-var" : "kaynak-yok")">
                        <div class="kaynak-baslik">Sosyal Güvenlik Kayıt Belgesi</div>
                        <div class="kaynak-durum">
                            @if (hasSocialSecDoc)
                            {
                                <span style="color:#15803d;">&#10003; Yüklendi — @socialSec!.CreatedAt.ToString("dd.MM.yyyy")</span>
                            }
                            else
                            {
                                <span style="color:#b45309;">&#9888; Henüz yüklenmedi</span>
                                <div style="font-size:12px;color:#6b7280;margin-top:4px;">
                                    Aşağıdaki belge yükleme alanından yükleyebilirsiniz.
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Belge yükleme *@
            <div class="upload-card" style="margin-bottom:20px;">
                <div>
                    <h2>Sosyal Güvenlik Kayıt Belgesi @(hasSocialSecDoc ? "— Güncelle" : "Yükle")</h2>
                    <p style="color:#6b7280;margin:4px 0 0;font-size:13px;">
                        @(hasSocialSecDoc
                            ? "Güncel belgeniz varsa yeni yükleyebilirsiniz; sistem son yüklenen belgeyi kullanır."
                            : "e-Devlet'teki \"Sosyal Güvenlik Kayıt Belgesi Sorgulama\" sayfasından indirdiğiniz PDF'i yükleyin.")
                    </p>
                </div>
                <form method="post" enctype="multipart/form-data" class="upload-form">
                    @Html.AntiForgeryToken()
                    <input type="file" name="SocialSecurityPdf" accept="application/pdf" />
                    <button type="submit">@(hasSocialSecDoc ? "Yeni Belge Yükle" : "Belgeyi Yükle")</button>
                </form>
            </div>

            @* Manuel bilgi formu *@
            <div class="premium-detail-card" style="margin-bottom:20px;">
                <h2>Kişisel Bilgilerinizi Girin</h2>
                <p style="color:#6b7280;margin:0 0 18px;font-size:13px;">
                    Eksik bilgiyle de devam edebilirsiniz; ancak analiz daha sınırlı kalır.
                </p>
                <form method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SocialSecurityPdf" value="" />

                    <div class="form-grid-2" style="margin-bottom:18px;">
                        <div class="form-group">
                            <label asp-for="BirthDate">Doğum Tarihi</label>
                            <input asp-for="BirthDate" type="date" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label asp-for="Gender">Cinsiyet</label>
                            <select asp-for="Gender" class="form-input">
                                <option value="">Seçiniz</option>
                                <option value="Erkek">Erkek</option>
                                <option value="Kadın">Kadın</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label asp-for="FirstInsuranceDate">İlk Sigorta Tarihi (opsiyonel)</label>
                            <input asp-for="FirstInsuranceDate" type="date" class="form-input"
                                   value="@(Model.FirstInsuranceDate?.ToString("yyyy-MM-dd") ?? "")" />
                            @if (firstDate.HasValue && !Model.FirstInsuranceDate.HasValue)
                            {
                                <span style="font-size:12px;color:#6b7280;margin-top:3px;">
                                    Otomatik tespit: <strong>@firstDate.Value.ToString("dd.MM.yyyy")</strong>
                                    (@firstDateSource). Yanlışsa düzeltebilirsiniz.
                                </span>
                            }
                        </div>
                        <div class="form-group">
                            <label asp-for="TargetStatus">Sigorta Statüsü</label>
                            <select asp-for="TargetStatus" class="form-input">
                                <option value="Bilmiyorum">Bilmiyorum / Belirlenemedi</option>
                                <option value="4A">4A — SSK (Ücretli/Sigortalı Çalışan)</option>
                                <option value="4B">4B — Bağ-Kur (Bağımsız / Kendi Hesabına)</option>
                                <option value="4C">4C — Emekli Sandığı (Kamu Görevlisi)</option>
                            </select>
                            @if (hasStatusFromDoc)
                            {
                                <span style="font-size:12px;color:#15803d;margin-top:3px;">
                                    Belgeden okundu: <strong>@dominantStatus</strong>
                                </span>
                            }
                        </div>
                    </div>

                    <details style="margin-bottom:18px;">
                        <summary style="font-weight:700;color:#004B93;font-size:14px;cursor:pointer;padding:8px 0;user-select:none;">
                            + e-Devlet "Ne Zaman Emekli Olabilirim?" Sonucu (İsteğe Bağlı)
                        </summary>
                        <div style="padding:12px 0;">
                            <p style="color:#6b7280;font-size:13px;margin:0 0 12px;">
                                e-Devlet sonucunu girerseniz eksik gün ve yaş karşılaştırması yapılır.
                            </p>
                            <div class="form-grid-3">
                                <div class="form-group">
                                    <label asp-for="EstimatedRetirementDate">Tahmini Emeklilik Tarihi</label>
                                    <input asp-for="EstimatedRetirementDate" type="date" class="form-input" />
                                </div>
                                <div class="form-group">
                                    <label asp-for="RequiredPremiumDays">Gereken Prim Günü</label>
                                    <input asp-for="RequiredPremiumDays" type="number" class="form-input" placeholder="Örn: 7200" />
                                </div>
                                <div class="form-group">
                                    <label asp-for="RequiredAge">Gereken Yaş</label>
                                    <input asp-for="RequiredAge" type="number" class="form-input" placeholder="Örn: 58" />
                                </div>
                            </div>
                        </div>
                    </details>

                    <details style="margin-bottom:18px;">
                        <summary style="font-weight:700;color:#004B93;font-size:14px;cursor:pointer;padding:8px 0;user-select:none;">
                            + Borçlanma Durumu (İsteğe Bağlı)
                        </summary>
                        <div style="padding:12px 0;">
                            <div class="form-grid-3">
                                @if (!isFemale)
                                {
                                    <div class="form-group">
                                        <label asp-for="MilitaryDebt">Askerlik Borçlanması</label>
                                        <select asp-for="MilitaryDebt" class="form-input">
                                            <option value="Bilmiyorum">Bilmiyorum</option>
                                            <option value="Yapıldı">Yapıldı</option>
                                            <option value="Evet">Yapmayı düşünüyorum</option>
                                            <option value="Hayır">Hayır</option>
                                        </select>
                                    </div>
                                }
                                @if (!isMale)
                                {
                                    <div class="form-group">
                                        <label asp-for="MaternityDebt">Doğum Borçlanması</label>
                                        <select asp-for="MaternityDebt" class="form-input">
                                            <option value="Bilmiyorum">Bilmiyorum</option>
                                            <option value="Yapıldı">Yapıldı</option>
                                            <option value="Evet">Yapmayı düşünüyorum</option>
                                            <option value="Hayır">Hayır</option>
                                        </select>
                                    </div>
                                }
                                <div class="form-group">
                                    <label asp-for="AbroadDebt">Yurt Dışı Borçlanma</label>
                                    <select asp-for="AbroadDebt" class="form-input">
                                        <option value="Bilmiyorum">Bilmiyorum</option>
                                        <option value="Evet">Evet / Yapıldı</option>
                                        <option value="Hayır">Hayır</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </details>

                    <button type="submit" class="btn-primary">Değerlendirmeyi Güncelle</button>
                </form>
            </div>

            @* Temel Bilgi Durumu — forma bağlı dinamik uyarı *@
            @{
                bool basicInfoComplete = hasBirthDate && hasGender && hasFirstDate && hasStatus;
                var missingFields = new List<string>();
                if (!hasBirthDate) missingFields.Add("Doğum tarihi");
                if (!hasGender) missingFields.Add("Cinsiyet");
                if (!hasFirstDate) missingFields.Add("İlk sigorta tarihi");
                if (!hasStatus) missingFields.Add("Sigorta statüsü");
            }
            <div class="info-alert @(basicInfoComplete ? "info-alert--ok" : "info-alert--warn")" style="margin-bottom:20px;">
                @if (basicInfoComplete)
                {
                    <div class="info-alert-icon">✅</div>
                    <div>
                        <div class="info-alert-title">Temel bilgiler tamamlandı</div>
                        <div class="info-alert-text">Doğum tarihi, cinsiyet ve statü bilgisi mevcut olduğu için ön değerlendirme daha anlamlı yapılabilir.</div>
                    </div>
                }
                else
                {
                    <div class="info-alert-icon">⚠️</div>
                    <div>
                        <div class="info-alert-title">Eksik bilgi var</div>
                        <div class="info-alert-text">
                            Doğum tarihi, cinsiyet veya statü bilgisi eksik olduğu için değerlendirme sınırlı yapılır.
                        </div>
                        <div class="info-alert-missing">Eksik alanlar: @string.Join(", ", missingFields)</div>
                    </div>
                }
            </div>

            @* ── ANALİZ KARTLARI ──────────────────────────────────────────── *@
            @if (hasPremiumDoc || hasSocialSecDoc)
            {
                <h3 class="rs-subsection-title">Ön Değerlendirme</h3>
                <div class="analysis-cards-grid">

                    @* Kart 1: İlk Başlangıç *@
                    <div class="analysis-card @(resolved?.HasConflict == true ? "analysis-card--warn" : "")">
                        <div class="ac-icon">📅</div>
                        <div class="ac-title">İlk Sigorta Başlangıcı</div>
                        @if (firstDate.HasValue)
                        {
                            <div class="ac-value">@firstDate.Value.ToString("dd.MM.yyyy")</div>
                            <div class="ac-note">
                                @if (resolved?.HasConflict == true)
                                {
                                    <span>Hizmet dökümünde kayıt belgesinden eski bir kayıt bulundu. Bu tarih dikkate alındı.</span>
                                }
                                else
                                {
                                    <span>Kaynak: @firstDateSource</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="ac-value ac-value--empty">Belirlenemedi</div>
                            <div class="ac-note">Hizmet Dökümü veya Kayıt Belgesi yükleyin.</div>
                        }
                    </div>

                    @* Kart 2: Prim Durumu *@
                    <div class="analysis-card">
                        <div class="ac-icon">📋</div>
                        <div class="ac-title">Prim Durumu</div>
                        @if (totalDays > 0)
                        {
                            <div class="ac-value">@totalDays.ToString("N0") gün</div>
                            @if (manual?.RequiredPremiumDays.HasValue == true)
                            {
                                int req  = manual.RequiredPremiumDays.Value;
                                int diff = req - totalDays;
                                if (diff > 0)
                                {
                                    <div class="ac-note ac-note--warn">
                                        Gereken: @req.ToString("N0") gün — <strong>@diff.ToString("N0") gün eksik</strong>
                                    </div>
                                }
                                else
                                {
                                    <div class="ac-note ac-note--ok">Prim günü koşulu karşılanmış görünüyor.</div>
                                }
                            }
                            else
                            {
                                <div class="ac-note">Gereken prim günü girilirse eksik gün hesabı yapılır.</div>
                            }
                        }
                        else
                        {
                            <div class="ac-value ac-value--empty">Belge yok</div>
                            <div class="ac-note">SGK Hizmet Dökümü yükleyin.</div>
                        }
                    </div>

                    @* Kart 3: Sigortalılık Süresi *@
                    <div class="analysis-card">
                        <div class="ac-icon">⏱️</div>
                        <div class="ac-title">Sigortalılık Süresi</div>
                        @if (insuranceYears.HasValue)
                        {
                            int iy = (int)insuranceYears.Value;
                            int im = (int)((insuranceYears.Value - iy) * 12);
                            <div class="ac-value">~@iy yıl @im ay</div>
                            @if (manual?.RequiredInsuranceYears.HasValue == true)
                            {
                                int req = manual.RequiredInsuranceYears.Value;
                                if (iy < req)
                                {
                                    <div class="ac-note ac-note--warn">Gereken @req yıl — @(req - iy) yıl daha gerekiyor.</div>
                                }
                                else
                                {
                                    <div class="ac-note ac-note--ok">Sigortalılık süresi koşulu karşılanmış görünüyor.</div>
                                }
                            }
                            else
                            {
                                <div class="ac-note">İlk başlangıç tarihine (@firstDateSource) göre hesaplandı.</div>
                            }
                        }
                        else
                        {
                            <div class="ac-value ac-value--empty">Belirlenemedi</div>
                            <div class="ac-note">İlk sigorta tarihi gereklidir.</div>
                        }
                    </div>

                    @* Kart 4: Statü Durumu *@
                    <div class="analysis-card @(multipleStatuses ? "analysis-card--warn" : "")">
                        <div class="ac-icon">🏷️</div>
                        <div class="ac-title">Statü Durumu</div>
                        @if (dominantStatus != "Belirsiz")
                        {
                            <div class="ac-value">@dominantStatus</div>
                            @if (!multipleStatuses && days4B == 0 && days4C == 0 && socialSec != null)
                            {
                                <div class="ac-note ac-note--ok">4B ve 4C görünmediği için farklı statü riski tespit edilmedi.</div>
                            }
                            else if (multipleStatuses)
                            {
                                <div class="ac-note ac-note--warn">Farklı statüler var. <a href="/Citizen/ServiceMerge" style="color:#b45309;font-weight:700;">Hizmet Birleştirme →</a></div>
                            }
                            else if (!hasSocialSecDoc)
                            {
                                <div class="ac-note">Kayıt Belgesi yüklenirse statü doğrulanır.</div>
                            }
                        }
                        else
                        {
                            <div class="ac-value ac-value--empty">Belirlenemedi</div>
                            <div class="ac-note">Kayıt Belgesi yükleyin veya statüyü seçin.</div>
                        }
                    </div>

                    @* Kart 5: EYT Ön Kontrolü *@
                    <div class="analysis-card @(isEytScope == true ? "analysis-card--warn" : "")">
                        <div class="ac-icon">🔍</div>
                        <div class="ac-title">EYT Ön Kontrolü</div>
                        @if (isEytScope == true)
                        {
                            <div class="ac-value" style="font-size:15px;">Kontrol Edilmeli</div>
                            <div class="ac-note ac-note--warn">
                                Başlangıç tarihi @firstDate!.Value.ToString("dd.MM.yyyy") — EYT dönemi içinde görünüyor.
                                Prim ve sigortalılık süresi ayrıca değerlendirilmelidir.
                            </div>
                        }
                        else if (isEytScope == false)
                        {
                            <div class="ac-value" style="font-size:15px;">Kapsamda Görünmüyor</div>
                            <div class="ac-note">Başlangıç tarihi 08.09.1999 sonrası; mevcut belgelere göre EYT kapsamında görünmüyor.</div>
                        }
                        else
                        {
                            <div class="ac-value ac-value--empty">Belirlenemedi</div>
                            <div class="ac-note">İlk sigorta tarihi bilinince kontrol yapılabilir.</div>
                        }
                    </div>

                    @* Kart 6: Emekli Aylığı *@
                    <div class="analysis-card">
                        <div class="ac-icon">💰</div>
                        <div class="ac-title">Emekli Aylığı Tahmini</div>
                        <div class="ac-value" style="font-size:14px;font-weight:600;color:#6b7280;">Net maaş hesaplanamaz</div>
                        <div class="ac-note">
                            Bu belgeler emekli aylığını kesin hesaplamak için yeterli değildir.
                            Resmi hesaplama için aşağıdaki SGK araçlarını kullanın.
                        </div>
                    </div>

                </div>

                @* ── Detaylı analiz — mevcut kartları koru ────────────────── *@
                @if (formSubmitted || hasSocialSecDoc)
                {
                    @if (hasSocialSecDoc && socialSec != null)
                    {
                        <div class="premium-detail-card" style="margin-bottom:18px;">
                            <h2>Statü Detayı</h2>
                            <div class="premium-summary-grid" style="margin-bottom:14px;">
                                <div class="premium-box">
                                    <span>4A (SSK) Günü</span>
                                    <strong>@(socialSec.Days4A?.ToString("N0") ?? "—")</strong>
                                </div>
                                <div class="premium-box">
                                    <span>4B (Bağ-Kur) Günü</span>
                                    <strong>@(socialSec.Days4B?.ToString("N0") ?? "—")</strong>
                                </div>
                                <div class="premium-box">
                                    <span>4C (Em. Sandığı) Günü</span>
                                    <strong>@(socialSec.Days4C?.ToString("N0") ?? "—")</strong>
                                </div>
                                <div class="premium-box">
                                    <span>Toplam (Kayıt Belgesi)</span>
                                    <strong>@(socialSec.TotalDays?.ToString("N0") ?? "—")</strong>
                                </div>
                            </div>
                            @if (socialSec.FirstRegistrationDate.HasValue)
                            {
                                <p style="color:#6b7280;font-size:13px;margin:0;">
                                    Kayıt Belgesindeki tescil tarihi: <strong>@socialSec.FirstRegistrationDate.Value.ToString("dd.MM.yyyy")</strong>
                                </p>
                            }
                        </div>
                    }

                    @if (premium != null && !string.IsNullOrWhiteSpace(premium.LastPeriod))
                    {
                        <div class="premium-detail-card" style="margin-bottom:18px;">
                            <h2>Son Bildirim Durumu</h2>
                            <p style="color:#4b5563;font-size:14px;line-height:1.7;margin:0;">
                                Son bildirilen dönem: <strong>@premium.LastPeriod</strong>.
                                SGK bildirimleri geriden yansıyabileceğinden içinde bulunulan ayın kaydı henüz sisteme düşmemiş olabilir.
                                @if (premium.HasMissingDays)
                                {
                                    <span>
                                        Bazı dönemlerde 30 günden az bildirim var — nedeni işe giriş/çıkış veya kısmi çalışma olabilir.
                                        <a href="/Citizen/PremiumInfo" style="color:#005BAC;font-weight:700;">Prim Bilgilerim →</a>
                                    </span>
                                }
                            </p>
                        </div>
                    }

                    @if (avgPek.HasValue)
                    {
                        <div class="premium-detail-card" style="margin-bottom:18px;">
                            <h2>PEK (Prime Esas Kazanç)</h2>
                            <div style="display:flex;gap:24px;flex-wrap:wrap;margin-bottom:10px;">
                                <div>
                                    <div style="font-size:12px;color:#6b7280;">Ortalama PEK</div>
                                    <div style="font-size:20px;font-weight:800;color:#0f172a;">@avgPek.Value.ToString("N2", trCulture) TL</div>
                                </div>
                                @if (lastPek.HasValue)
                                {
                                    <div>
                                        <div style="font-size:12px;color:#6b7280;">Son Dönem PEK</div>
                                        <div style="font-size:20px;font-weight:800;color:#0f172a;">@lastPek.Value.ToString("N2", trCulture) TL</div>
                                    </div>
                                }
                            </div>
                            <p style="color:#6b7280;font-size:13px;margin:0;">
                                @if (lastPek.HasValue && avgPek.HasValue)
                                {
                                    if (lastPek.Value > avgPek.Value * 1.05m)
                                    {
                                        <span>Son bildirilen kazanç ortalamanızın üzerinde görünüyor.</span>
                                    }
                                    else if (lastPek.Value < avgPek.Value * 0.95m)
                                    {
                                        <span>Son bildirilen kazanç ortalamanızın altında görünüyor.</span>
                                    }
                                    else
                                    {
                                        <span>Son bildirilen kazanç ortalamanıza yakın görünüyor.</span>
                                    }
                                }
                                Bildirilen kazanç düzeyi emekli aylığını etkileyen unsurlardan biridir; ancak kesin hesaplama için SGK araçlarını kullanın.
                            </p>
                        </div>
                    }

                    @if (manual?.EstimatedRetirementDate.HasValue == true)
                    {
                        var retDate = manual.EstimatedRetirementDate.Value;
                        var diff    = retDate - DateTime.Now;
                        <div class="premium-detail-card" style="margin-bottom:18px;">
                            <h2>e-Devlet Karşılaştırması</h2>
                            <p style="color:#4b5563;font-size:14px;line-height:1.7;margin:0;">
                                e-Devlet'e göre tahmini emeklilik tarihi <strong>@retDate.ToString("MMMM yyyy", trCulture)</strong>.
                                @if (diff.TotalDays > 0)
                                {
                                    int dy = (int)(diff.TotalDays / 365);
                                    int dm = (int)((diff.TotalDays % 365) / 30);
                                    <span>Bu tarihe yaklaşık <strong>@(dy > 0 ? dy + " yıl " : "")@(dm > 0 ? dm + " ay" : "az bir süre")</strong> kalmaktadır.</span>
                                }
                                else
                                {
                                    <span style="color:#15803d;font-weight:700;">Bu tarihe göre emeklilik koşulları karşılanmış olabilir. SGK'ya başvurunuz.</span>
                                }
                            </p>
                        </div>
                    }
                }
            }
            else
            {
                <div class="premium-detail-card" style="color:#6b7280;font-size:14px;border-left:4px solid #e5e7eb;">
                    Analiz kartları görüntülemek için SGK Hizmet Dökümü veya Sosyal Güvenlik Kayıt Belgesi yükleyin.
                </div>
            }

            @* ── RESMİ SGK HESAPLAMA ARAÇLARI ─────────────────────────── *@
            <h3 class="rs-subsection-title" style="margin-top:32px;">Resmi SGK Hesaplama Araçları</h3>
            <p style="color:#6b7280;font-size:13px;margin:0 0 18px;">
                Kesin emeklilik tarihi ve aylık hesabı için SGK'nın resmi araçlarını kullanın.
                @if (statusGroup != "Belirsiz")
                {
                    <span>Statünüze uygun araçlar <span class="sgk-badge-recommended">Önerilen</span> etiketi ile gösterilmektedir.</span>
                }
            </p>

            <div class="sgk-tools-grid">

                @* 4A Araçları *@
                <a href="https://uyg.sgk.gov.tr/nezaman/" target="_blank" rel="noopener noreferrer"
                   class="sgk-tool-card @(statusGroup == "4A" ? "sgk-tool-card--recommended" : "")">
                    @if (statusGroup == "4A")
                    {
                        <span class="sgk-badge-recommended">Önerilen</span>
                    }
                    <div class="sgk-tool-icon">🗓️</div>
                    <div class="sgk-tool-title">4A — Ne Zaman Emekli Olabilirim?</div>
                    <div class="sgk-tool-desc">4A çalışanları için SGK'nın resmi emeklilik zamanı sorgulama aracıdır.</div>
                    <div class="sgk-tool-btn">SGK'da Aç →</div>
                </a>

                <a href="https://giris.turkiye.gov.tr/Giris/gir" target="_blank" rel="noopener noreferrer"
                   class="sgk-tool-card @(statusGroup == "4A" ? "sgk-tool-card--recommended" : "")">
                    @if (statusGroup == "4A")
                    {
                        <span class="sgk-badge-recommended">Önerilen</span>
                    }
                    <div class="sgk-tool-icon">💵</div>
                    <div class="sgk-tool-title">4A — Aylık Hesaplama</div>
                    <div class="sgk-tool-desc">4A çalışanları için e-Devlet üzerinden erişilen resmi aylık hesaplama aracıdır.</div>
                    <div class="sgk-tool-btn">e-Devlet'te Aç →</div>
                </a>

                @* 4B Araçları *@
                <a href="https://uyg.sgk.gov.tr/EMEKTARWEB/hakKazanma.do" target="_blank" rel="noopener noreferrer"
                   class="sgk-tool-card @(statusGroup == "4B" ? "sgk-tool-card--recommended" : "")">
                    @if (statusGroup == "4B")
                    {
                        <span class="sgk-badge-recommended">Önerilen</span>
                    }
                    <div class="sgk-tool-icon">🗓️</div>
                    <div class="sgk-tool-title">4B — Ne Zaman Emekli Olabilirim?</div>
                    <div class="sgk-tool-desc">4B / Bağ-Kur kapsamındaki kullanıcılar için SGK'nın emeklilik zamanı hesaplama aracıdır.</div>
                    <div class="sgk-tool-btn">SGK'da Aç →</div>
                </a>

                <a href="https://giris.turkiye.gov.tr/Giris/gir" target="_blank" rel="noopener noreferrer"
                   class="sgk-tool-card @(statusGroup == "4B" ? "sgk-tool-card--recommended" : "")">
                    @if (statusGroup == "4B")
                    {
                        <span class="sgk-badge-recommended">Önerilen</span>
                    }
                    <div class="sgk-tool-icon">💵</div>
                    <div class="sgk-tool-title">4B — Aylık Hesaplama</div>
                    <div class="sgk-tool-desc">4B sigortalıları için e-Devlet üzerinden erişilen resmi aylık hesaplama aracıdır.</div>
                    <div class="sgk-tool-btn">e-Devlet'te Aç →</div>
                </a>

                @* 4C Araçları *@
                <a href="https://uyg.sgk.gov.tr/HizmetHesabi4c/" target="_blank" rel="noopener noreferrer"
                   class="sgk-tool-card @(statusGroup == "4C" ? "sgk-tool-card--recommended" : "")">
                    @if (statusGroup == "4C")
                    {
                        <span class="sgk-badge-recommended">Önerilen</span>
                    }
                    <div class="sgk-tool-icon">🗓️</div>
                    <div class="sgk-tool-title">4C — Ne Zaman Emekli Olabilirim?</div>
                    <div class="sgk-tool-desc">4C / kamu çalışanları için SGK'nın emeklilik hizmet süresi ve yaş hesabı aracıdır.</div>
                    <div class="sgk-tool-btn">SGK'da Aç →</div>
                </a>

                <a href="https://giris.turkiye.gov.tr/Giris/gir" target="_blank" rel="noopener noreferrer"
                   class="sgk-tool-card @(statusGroup == "4C" ? "sgk-tool-card--recommended" : "")">
                    @if (statusGroup == "4C")
                    {
                        <span class="sgk-badge-recommended">Önerilen</span>
                    }
                    <div class="sgk-tool-icon">💵</div>
                    <div class="sgk-tool-title">4C — İkramiye / Maaş Hesaplama</div>
                    <div class="sgk-tool-desc">4C çalışanları için e-Devlet üzerinden erişilen ikramiye ve maaş hesaplama aracıdır.</div>
                    <div class="sgk-tool-btn">e-Devlet'te Aç →</div>
                </a>

                @* Genel e-Devlet *@
                <a href="https://giris.turkiye.gov.tr/Giris/gir" target="_blank" rel="noopener noreferrer"
                   class="sgk-tool-card">
                    <div class="sgk-tool-icon">🌐</div>
                    <div class="sgk-tool-title">e-Devlet Girişi</div>
                    <div class="sgk-tool-desc">SGK hizmetleri ve resmi sorgulama ekranlarına e-Devlet üzerinden erişebilirsiniz.</div>
                    <div class="sgk-tool-btn">e-Devlet'te Aç →</div>
                </a>

            </div>

            @* Bilgilendirme notu *@
            <div class="premium-detail-card" style="border-left:4px solid #005BAC;margin-top:12px;margin-bottom:20px;">
                <p style="color:#4b5563;font-size:13px;line-height:1.7;margin:0;">
                    Bu ekran yüklenen belgeler üzerinden ön değerlendirme sunar; kesin emeklilik kararı vermez.
                    Farklı statü, eksik kayıt veya hatalı prim bildirimi durumlarında SGK ile görüşmeniz gerekir.
                    <strong>Resmi başvuru ve kesin sonuç için SGK kayıtları esas alınır.</strong>
                </p>
            </div>

        </section>

    </main>
</section>

<style>
    /* Veri kaynakları */
    .veri-kaynak-grid  { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
    .veri-kaynak-item  { border:1px solid #e5e7eb; border-radius:10px; padding:14px 16px; background:#f9fafb; }
    .kaynak-var        { border-left:4px solid #15803d; }
    .kaynak-yok        { border-left:4px solid #b45309; }
    .kaynak-baslik     { font-weight:700; color:#111827; margin-bottom:6px; font-size:13px; }
    .kaynak-durum      { font-size:13px; }

