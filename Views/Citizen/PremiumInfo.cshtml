@model EmekliRehberi.ViewModels.PremiumUploadViewModel
@using EmekliRehberi.Models
@using System.Linq

@{
    ViewData["Title"] = "Prim Bilgilerim";
    ViewData["ActivePage"] = "PremiumInfo";

    var doc = ViewBag.LatestPremiumDocument as PremiumDocument;

    var monthlyRecords = doc?.Records?
        .Where(r => !r.IsYearTotal)
        .OrderByDescending(r => r.Period)
        .ToList() ?? new List<PremiumRecord>();

    var missingDayRecords = monthlyRecords
        .Where(r => r.Days > 0 && r.Days < 30)
        .ToList();

    var pekRecords = monthlyRecords.Where(r => r.PekAmount.HasValue).ToList();
    decimal? avgPek = pekRecords.Any() ? pekRecords.Average(r => r.PekAmount!.Value) : null;
    decimal? minPek = pekRecords.Any() ? pekRecords.Min(r => r.PekAmount!.Value) : null;
    decimal? maxPek = pekRecords.Any() ? pekRecords.Max(r => r.PekAmount!.Value) : null;
    decimal? lastPek = monthlyRecords.FirstOrDefault()?.PekAmount;

    bool lastPeriodFull = monthlyRecords.FirstOrDefault()?.Days == 30;
    int totalDays = doc?.TotalPremiumDays ?? 0;
    int eksikGunSayisi = missingDayRecords.Count;

    DateTime? firstEntryDate = monthlyRecords
        .Where(r => r.EntryDate.HasValue)
        .OrderBy(r => r.EntryDate)
        .Select(r => r.EntryDate)
        .FirstOrDefault();

    string belgeTuruFallback =
        (doc?.DocumentType != null && doc.DocumentType.IndexOf("Hizmet Dökümü", StringComparison.OrdinalIgnoreCase) >= 0)
            ? "4A / Hizmet Dökümü" : "—";

    // PEK bar grafiği: PEK'i olan en güncel 6 dönem, azalan dönem sırasıyla
    var pekChartRecords = pekRecords.Take(6).ToList();
    decimal pekChartMax = pekChartRecords.Any() ? pekChartRecords.Max(r => r.PekAmount!.Value) : 0m;

    // Tablo filtresi için indexli liste (foreach içinde @{} açmamak için)
    var indexedMonthlyRecords = monthlyRecords
        .Select((r, idx) => new { Record = r, Index = idx })
        .ToList();
}

<section class="dashboard-page">
    @await Html.PartialAsync("_CitizenSidebar")

    <main class="dashboard-content">

        <div class="page-title">
            <h1>Prim Bilgilerim</h1>
        </div>

        @* ── Sekme butonları ───────────────────────────────────────────── *@
        <div class="pi-tabs" role="tablist" aria-label="Prim Bilgilerim sekmeleri">
            <button type="button" class="pi-tab pi-tab--active" data-tab="rehber" onclick="piSwitchTab('rehber')">
                Prim Rehberi
            </button>
            <button type="button" class="pi-tab" data-tab="analiz" onclick="piSwitchTab('analiz')">
                PDF Analizi
            </button>
        </div>

        @* ════════════════════════════════════════════════════════════════
           SEKME 1 — PRİM REHBERİ
        ════════════════════════════════════════════════════════════════ *@
        <div class="pi-tab-panel pi-tab-panel--active" id="pi-panel-rehber">
            <p class="pi-guide-intro">
                Bu bölüm, hizmet dökümü ve prim bilgilerinde sık karşılaşılan temel kavramları açıklar.
                PDF Analizi sekmesinde ise yüklenen belgeye ait dönemsel kayıtlar, PEK bilgileri ve eksik gün durumu ayrıca gösterilir.
            </p>

            <div class="pi-info-grid">
                <div class="pi-info-card">
                    <span class="pi-info-icon">📅</span>
                    <div>
                        <h3>Prim Günü</h3>
                        <p>
                            Sigortalı olarak çalışılan ve SGK’ya bildirilen gün sayısını ifade eder.
                            Emeklilik koşullarında prim günü önemli bir kriterdir; ancak tek başına yeterli değildir.
                        </p>
                    </div>
                </div>

                <div class="pi-info-card">
                    <span class="pi-info-icon">📌</span>
                    <div>
                        <h3>Uzun Vade Prim Günü</h3>
                        <p>
                            Yaşlılık, malullük ve ölüm sigortası gibi uzun vadeli sigorta kollarına bildirilen prim günüdür.
                            Emeklilik değerlendirmelerinde genellikle uzun vade prim gün sayısı esas alınır.
                        </p>
                    </div>
                </div>

                <div class="pi-info-card">
                    <span class="pi-info-icon">💰</span>
                    <div>
                        <h3>P.E.K. Bilgisi</h3>
                        <p>
                            Prime Esas Kazanç, çalışanın SGK’ya bildirilen kazanç matrahıdır.
                            Emekli aylığı hesabını etkileyebilen unsurlardan biridir ve dönemsel olarak değişiklik gösterebilir.
                        </p>
                    </div>
                </div>

                <div class="pi-info-card">
                    <span class="pi-info-icon">⏳</span>
                    <div>
                        <h3>Son Bildirilen Dönem</h3>
                        <p>
                            Hizmet dökümünde görünen en güncel sigortalılık dönemini gösterir.
                            SGK bildirimleri bazı durumlarda sisteme gecikmeli yansıyabileceği için güncel kayıt e-Devlet üzerinden kontrol edilmelidir.
                        </p>
                    </div>
                </div>

                <div class="pi-info-card">
                    <span class="pi-info-icon">⚠️</span>
                    <div>
                        <h3>Eksik Gün</h3>
                        <p>
                            Bir ayda 30 günden az prim bildirimi bulunması durumudur.
                            İşe giriş veya çıkış, raporlu süre, ücretsiz izin ya da kısmi süreli çalışma gibi nedenlerden kaynaklanabilir.
                        </p>
                    </div>
                </div>

                <div class="pi-info-card">
                    <span class="pi-info-icon">🏷️</span>
                    <div>
                        <h3>4A / 4B / 4C Statüsü</h3>
                        <p>
                            4A, 4B ve 4C farklı sigorta statülerini ifade eder.
                            Farklı statülerde hizmet bulunması halinde emeklilik statüsü ve hizmet birleştirme açısından ayrıca değerlendirme gerekebilir.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        @* ════════════════════════════════════════════════════════════════
           SEKME 2 — PDF ANALİZİ
        ════════════════════════════════════════════════════════════════ *@
        <div class="pi-tab-panel" id="pi-panel-analiz" style="display:none;">


        @* ── 1. Belge Yükleme ─────────────────────────────────────────── *@
        <div class="upload-card">
            <div>
                <h2>SGK Tescil ve Hizmet Dökümü Yükle</h2>
                @if (doc != null)
                {
                    <p>
                        <strong>@doc.OriginalFileName</strong> adlı belge
                        @doc.CreatedAt.ToString("dd.MM.yyyy HH:mm") tarihinde sisteme yüklenmiştir.
                        Güncel bir belge yüklemek isterseniz yeni dosyayı seçerek işlemi tekrarlayabilirsiniz;
                        sistem en son yüklenen belgeyi esas alır.
                    </p>
                }
                else
                {
                    <p>Prim bilgilerinizin analiz edilebilmesi için SGK Tescil ve Hizmet Dökümü PDF belgenizi yükleyiniz.</p>
                }
            </div>
            <form method="post" enctype="multipart/form-data" class="upload-form">
                <input asp-for="PdfFile" type="file" accept="application/pdf" />
                <span asp-validation-for="PdfFile" class="text-danger"></span>
                <button type="submit">@(doc == null ? "Belgeyi Yükle" : "Yeni Belge Yükle")</button>
            </form>
        </div>

        @if (doc == null)
        {
            <div class="empty-service-warning">
                <h2>Henüz prim belgesi yüklenmemiştir</h2>
                <p>
                    Belge yüklendikten sonra dönemsel prim kayıtlarınız, prime esas kazanç bilgileriniz
                    ve eksik gün durumunuz otomatik olarak analiz edilecektir.
                </p>
            </div>
        }
        else
        {
            @* ── 2. Dönemsel Prim Kayıtları ────────────────────────────── *@
            <div class="premium-detail-card">
                <h2>Dönemsel Prim Kayıtları</h2>
                @if (monthlyRecords.Any())
                {
                    <div class="pi-filter-row">
                        <button type="button" class="pi-filter-btn pi-filter-btn--active" data-filter="all"     onclick="piFilterRecords('all')">Tüm Kayıtlar</button>
                        <button type="button" class="pi-filter-btn"                        data-filter="last12" onclick="piFilterRecords('last12')">Son 12 Dönem</button>
                        <button type="button" class="pi-filter-btn"                        data-filter="missing" onclick="piFilterRecords('missing')">Eksik Günler</button>
                    </div>
                    <table class="data-table" id="pi-records-table">
                        <thead>
                            <tr>
                                <th>Dönem</th>
                                <th>Gün</th>
                                <th>P.E.K.</th>
                                <th>Statü</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in indexedMonthlyRecords)
                            {
                                <tr data-index="@entry.Index" data-days="@entry.Record.Days">
                                    <td>@entry.Record.Period</td>
                                    <td>@entry.Record.Days</td>
                                    <td>@(entry.Record.PekAmount.HasValue ? entry.Record.PekAmount.Value.ToString("N2") + " TL" : "—")</td>
                                    <td>@(entry.Record.InsuranceStatus ?? entry.Record.DocumentType ?? belgeTuruFallback)</td>
                                    <td>
                                        @if (entry.Record.Days == 30)
                                        {
                                            <span style="color:#15803d;font-weight:600;">Tam ay</span>
                                        }
                                        else if (entry.Record.Days > 0 && entry.Record.Days < 30)
                                        {
                                            <span style="color:#b45309;font-weight:600;">30 günden az</span>
                                        }
                                        else
                                        {
                                            <span style="color:#9ca3af;">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <p id="pi-filter-empty" style="display:none;color:#9ca3af;font-size:13px;margin:10px 0 0;">Bu filtreye uygun kayıt bulunamadı.</p>
                }
                else
                {
                    <p style="color:#6b7280;">Dönemsel kayıtlar otomatik olarak ayrıştırılamadı.</p>
                }
            </div>

            @* ── 3. Prim Özeti ──────────────────────────────────────────── *@
            <div class="premium-detail-card">
                <h2>Prim Özeti</h2>
                <div class="premium-summary-grid">
                    <div class="premium-box">
                        <span>Toplam Prim Günü</span>
                        <strong>@(doc.TotalPremiumDays.HasValue ? doc.TotalPremiumDays.Value.ToString("N0") + " gün" : "Okunamadı")</strong>
                    </div>
                    <div class="premium-box">
                        <span>İlk Giriş Tarihi</span>
                        <strong>@(firstEntryDate.HasValue ? firstEntryDate.Value.ToString("dd.MM.yyyy") : "Okunamadı")</strong>
                    </div>
                    <div class="premium-box">
                        <span>Son Bildirilen Dönem</span>
                        <strong>@(!string.IsNullOrWhiteSpace(doc.LastPeriod) ? doc.LastPeriod : "Okunamadı")</strong>
                    </div>
                    <div class="premium-box">
                        <span>Eksik Gün Durumu</span>
                        <strong style="@(doc.HasMissingDays ? "color:#b45309;" : "color:#15803d;")">
                            @(doc.HasMissingDays ? "Eksik gün var" : "Görünmüyor")
                        </strong>
                    </div>
                    <div class="premium-box">
                        <span>Belge Türü</span>
                        <strong>@doc.DocumentType</strong>
                    </div>
                </div>
            </div>

            @* ── 4. PEK Özeti ───────────────────────────────────────────── *@
            <div class="premium-detail-card">
                <h2>PEK Özeti (Prime Esas Kazanç)</h2>
                <div class="premium-summary-grid">
                    <div class="premium-box">
                        <span>Son Dönem PEK</span>
                        <strong>@(lastPek.HasValue ? lastPek.Value.ToString("N2") + " TL" : "Okunamadı")</strong>
                    </div>
                    <div class="premium-box">
                        <span>Ortalama PEK</span>
                        <strong>@(avgPek.HasValue ? avgPek.Value.ToString("N2") + " TL" : "Okunamadı")</strong>
                    </div>
                    <div class="premium-box">
                        <span>En Yüksek PEK</span>
                        <strong>@(maxPek.HasValue ? maxPek.Value.ToString("N2") + " TL" : "Okunamadı")</strong>
                    </div>
                    <div class="premium-box">
                        <span>En Düşük PEK</span>
                        <strong>@(minPek.HasValue ? minPek.Value.ToString("N2") + " TL" : "Okunamadı")</strong>
                    </div>
                </div>
                <p class="pi-pek-yorum">
                    @if (!lastPek.HasValue || !avgPek.HasValue)
                    {
                        <span>PEK bilgisi bu belgede okunamadı veya belge formatı uygun değil.</span>
                    }
                    else if (lastPek.Value > avgPek.Value * 1.02m)
                    {
                        <span>Son dönem PEK, dönemsel ortalamanızın üzerindedir. Bildirilen kazanç düzeyi emekli aylığını etkileyen unsurlardan biridir; kesin hesaplama için SGK araçları kullanılmalıdır.</span>
                    }
                    else if (lastPek.Value < avgPek.Value * 0.98m)
                    {
                        <span>Son dönem PEK, dönemsel ortalamanızın altındadır. Ön bilgilendirme amaçlıdır; kesin sonuç için SGK kayıtları esas alınır.</span>
                    }
                    else
                    {
                        <span>Son dönem PEK, dönemsel ortalamanıza yakındır. Ön bilgilendirme amaçlıdır; kesin sonuç için SGK kayıtları esas alınır.</span>
                    }
                </p>
            </div>

            @* ── 5. Son Dönem PEK Görseli ───────────────────────────────── *@
            @if (pekChartRecords.Any())
            {
                <div class="premium-detail-card">
                    <h2>Son Dönem PEK Görseli</h2>
                    <div class="pi-pek-chart">
                        @foreach (var rec in pekChartRecords)
                        {
                            decimal barPct = pekChartMax > 0
                                ? Math.Round(rec.PekAmount!.Value / pekChartMax * 100, 1)
                                : 0m;
                            <div class="pi-pek-bar-row">
                                <div class="pi-pek-bar-label">@rec.Period</div>
                                <div class="pi-pek-bar-track">
                                    <div class="pi-pek-bar-fill" style="width:@barPct%;"></div>
                                </div>
                                <div class="pi-pek-bar-value">@rec.PekAmount!.Value.ToString("N2") TL</div>
                            </div>
                        }
                    </div>
                    <p style="color:#9ca3af;font-size:12px;margin:10px 0 0;">
                        En güncel @pekChartRecords.Count dönem gösterilmektedir. En uzun çubuk en yüksek PEK değerini temsil eder.
                    </p>
                </div>
            }

            @* ── 6. Eksik Gün Analizi ────────────────────────────────────── *@
            @if (missingDayRecords.Any())
            {
                <div class="premium-detail-card">
                    <h2>Eksik Gün Analizi</h2>
                    <p style="color:#6b7280;margin:0 0 14px;line-height:1.7;">
                        Aşağıdaki dönemlerde 30 günden az prim bildirimi görünmektedir.
                        Bu durum; işe giriş/çıkış, kısmi çalışma, ücretsiz izin veya raporlu süre gibi nedenlerden kaynaklanabilir.
                        Bilginiz dışında bir eksiklik olduğunu düşünüyorsanız işvereniniz veya SGK ile kontrol etmeniz önerilir.
                    </p>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Dönem</th>
                                <th>Bildirilen Gün</th>
                                <th>Eksik Gün</th>
                                <th>P.E.K.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in missingDayRecords)
                            {
                                <tr>
                                    <td>@item.Period</td>
                                    <td><strong>@item.Days gün</strong></td>
                                    <td style="color:#b45309;font-weight:600;">@(30 - item.Days) gün eksik</td>
                                    <td>@(item.PekAmount.HasValue ? item.PekAmount.Value.ToString("N2") + " TL" : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @* ── 7. Prim Bilgileriniz Ne Anlama Geliyor? ────────────────── *@
            <div class="premium-detail-card">
                <h2>Prim Bilgileriniz Ne Anlama Geliyor?</h2>
                <div class="prim-yorum-listesi">

                    <div class="yorum-satiri">
                        <div class="yorum-baslik">Toplam Prim Günü</div>
                        <div class="yorum-metin">
                            @if (doc.TotalPremiumDays.HasValue)
                            {
                                <span>Belgede toplam <strong>@doc.TotalPremiumDays.Value gün</strong> uzun vade prim bildirimi görünmektedir.</span>
                                if (totalDays < 3600)
                                {
                                    <span> Emeklilik için gereken asgari prim günü koşulunu henüz karşılamıyor olabilirsiniz.</span>
                                }
                                else if (totalDays < 5400)
                                {
                                    <span> Belirli emeklilik koşulları için yeterli olabilir; yaş ve sigortalılık süresi birlikte değerlendirilmelidir.</span>
                                }
                                else
                                {
                                    <span> Prim gün sayınız emeklilik değerlendirmesinde önemli bir eşiğe ulaşmış görünmektedir.</span>
                                }
                            }
                            else
                            {
                                <span>Toplam prim günü belgeden okunamadı.</span>
                            }
                        </div>
                    </div>

                    <div class="yorum-satiri">
                        <div class="yorum-baslik">Son Bildirilen Dönem</div>
                        <div class="yorum-metin">
                            @if (!string.IsNullOrWhiteSpace(doc.LastPeriod))
                            {
                                <span>Belgede en güncel kayıt <strong>@doc.LastPeriod</strong> dönemine aittir.</span>
                                if (lastPeriodFull)
                                {
                                    <span> Bu dönemde tam ay (30 gün) bildirimi görünmektedir.</span>
                                }
                                else
                                {
                                    <span> Bu dönemde eksik gün bildirimi görünmektedir.</span>
                                }
                                <span> SGK bildirimleri zaman zaman geriden yansıyabileceğinden güncel dönem belgede henüz görünmeyebilir.</span>
                            }
                            else
                            {
                                <span>Son dönem bilgisi belgeden okunamadı.</span>
                            }
                        </div>
                    </div>

                    <div class="yorum-satiri">
                        <div class="yorum-baslik">PEK Bilgileri</div>
                        <div class="yorum-metin">
                            @if (lastPek.HasValue && avgPek.HasValue)
                            {
                                <span>Son dönem PEK <strong>@lastPek.Value.ToString("N2") TL</strong>, dönemsel ortalama <strong>@avgPek.Value.ToString("N2") TL</strong> olarak görünmektedir.</span>
                                if (lastPek.Value > avgPek.Value * 1.02m)
                                {
                                    <span> Son dönem PEK ortalamanın üzerindedir.</span>
                                }
                                else if (lastPek.Value < avgPek.Value * 0.98m)
                                {
                                    <span> Son dönem PEK ortalamanın altındadır.</span>
                                }
                                else
                                {
                                    <span> Son dönem PEK ortalamayla uyumludur.</span>
                                }
                                <span> PEK, emekli aylığını etkileyen unsurlardan biridir; kesin hesaplama için SGK araçları kullanılmalıdır.</span>
                            }
                            else
                            {
                                <span>PEK bilgisi bu belgeden okunamadı.</span>
                            }
                        </div>
                    </div>

                    <div class="yorum-satiri">
                        <div class="yorum-baslik">Eksik Gün Durumu</div>
                        <div class="yorum-metin">
                            @if (eksikGunSayisi > 0)
                            {
                                <span><strong>@eksikGunSayisi dönemde</strong> 30 günden az bildirim görünmektedir.</span>
                                <span> Bu durum işe giriş/çıkış, kısmi çalışma veya ücretsiz izin gibi nedenlerden kaynaklanıyor olabilir. Beklenmediği hâllerde resmi kayıtlar kontrol edilmelidir.</span>
                            }
                            else
                            {
                                <span>Yüklenen belgede 30 günden az bildirim içeren dönem görünmemektedir.</span>
                            }
                        </div>
                    </div>

                    <div class="yorum-satiri" style="border-bottom:none;">
                        <div class="yorum-baslik">Genel Değerlendirme</div>
                        <div class="yorum-metin">
                            Bu analiz, yüklenen belgedeki okunabilir verilerden otomatik üretilmiştir.
                            Emeklilik değerlendirmesi için <strong>yaş, ilk sigorta başlangıcı, sigorta statüsü ve borçlanma</strong>
                            bilgileri ayrıca gereklidir. Kesin bilgi için SGK/e-Devlet kayıtları esas alınır.
                        </div>
                    </div>

                </div>
            </div>
        }

        @* ── 8. İlgili Resmi SGK/e-Devlet Hizmetleri ───────────────────── *@
        <section class="pi-tools-section">
            <div class="pi-tools-header">
                <span class="pi-tools-icon">🌐</span>
                <h2>İlgili Resmi SGK/e-Devlet Hizmetleri</h2>
            </div>
            <p style="color:#6b7280;font-size:13px;margin:0 0 16px;">
                Güncel ve resmi prim/hizmet bilgileriniz için aşağıdaki e-Devlet ekranlarını kullanabilirsiniz.
            </p>

            <div class="pi-tools-grid">
                <a href="https://www.turkiye.gov.tr/sgk-tescil-ve-hizmet-dokumu" target="_blank" rel="noopener noreferrer" class="pi-tool-card">
                    <div class="pi-tool-icon">📄</div>
                    <div class="pi-tool-title">SGK Tescil ve Hizmet Dökümü</div>
                    <div class="pi-tool-desc">Emekliliğe esas uzun vade hizmetlerinizi ve işyeri ünvan listenizi görüntüleyebilirsiniz.</div>
                    <div class="pi-tool-btn">e-Devlet'te Aç →</div>
                </a>
                <a href="https://www.turkiye.gov.tr/sosyal-guvenlik-kayit-belgesi-sorgulama" target="_blank" rel="noopener noreferrer" class="pi-tool-card">
                    <div class="pi-tool-icon">🪪</div>
                    <div class="pi-tool-title">Sosyal Güvenlik Kayıt Belgesi</div>
                    <div class="pi-tool-desc">4A, 4B ve 4C sigorta kayıt bilgilerinizi içeren barkodlu belgeyi alabilirsiniz.</div>
                    <div class="pi-tool-btn">e-Devlet'te Aç →</div>
                </a>
                <a href="https://www.turkiye.gov.tr/4a-hizmet-dokumu" target="_blank" rel="noopener noreferrer" class="pi-tool-card">
                    <div class="pi-tool-icon">🧾</div>
                    <div class="pi-tool-title">4A Hizmet Bilgileri (Son 6 Ay)</div>
                    <div class="pi-tool-desc">4A kapsamındaki yakın dönem hizmet bilgilerinizi görüntüleyebilirsiniz.</div>
                    <div class="pi-tool-btn">e-Devlet'te Aç →</div>
