<script>
(function () {

    window.piSwitchTab = function (tab) {
        var guidePanel = document.getElementById('pi-panel-rehber');
        var analysisPanel = document.getElementById('pi-panel-analiz');
        var buttons = document.querySelectorAll('.pi-tab');

        if (!guidePanel || !analysisPanel) return;

        var showGuide = tab === 'rehber';

        guidePanel.style.display = showGuide ? '' : 'none';
        analysisPanel.style.display = showGuide ? 'none' : '';

        guidePanel.classList.toggle('pi-tab-panel--active', showGuide);
        analysisPanel.classList.toggle('pi-tab-panel--active', !showGuide);

        buttons.forEach(function (button) {
            button.classList.toggle('pi-tab--active', button.getAttribute('data-tab') === tab);
        });
    };

    window.piFilterRecords = function (filter) {
        var table = document.getElementById('pi-records-table');
        if (!table) return;
        var btns = document.querySelectorAll('.pi-filter-btn');
        btns.forEach(function (b) { b.classList.toggle('pi-filter-btn--active', b.getAttribute('data-filter') === filter); });
        var rows = table.querySelectorAll('tbody tr');
        var visible = 0;
        rows.forEach(function (row) {
            var idx  = parseInt(row.getAttribute('data-index'), 10);
            var days = parseInt(row.getAttribute('data-days'), 10);
            var show = filter === 'all' || (filter === 'last12' && idx < 12) || (filter === 'missing' && days > 0 && days < 30);
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        var empty = document.getElementById('pi-filter-empty');
        if (empty) empty.style.display = visible === 0 ? '' : 'none';
    };
})();
</script>
