@using EmekliRehberi.Models

@{
    ViewData["Title"] = "Profilim";
    ViewData["ActivePage"] = "Profile";

    var currentUser = ViewBag.CurrentUser as AppUser;
    var hasUser = currentUser != null;

    var firstName = currentUser?.FirstName?.Trim() ?? "";
    var lastName = currentUser?.LastName?.Trim() ?? "";
    var email = currentUser?.Email?.Trim() ?? "";
    var tcKimlikNo = currentUser?.TcKimlikNo?.Trim() ?? "";
    var role = currentUser?.Role?.Trim() ?? "Vatandas";

    var displayFirstName = !string.IsNullOrWhiteSpace(firstName) ? firstName : "Kayıtlı değil";
    var displayLastName = !string.IsNullOrWhiteSpace(lastName) ? lastName : "Kayıtlı değil";
    var displayEmail = !string.IsNullOrWhiteSpace(email) ? email : "Kayıtlı değil";

    var fullName = "Kullanıcı bilgisi bulunamadı";
    if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
    {
        fullName = $"{firstName} {lastName}".Trim();
    }

    var roleText = "Vatandaş";
    if (!string.IsNullOrWhiteSpace(role))
    {
        if (role.Equals("Vatandas", StringComparison.OrdinalIgnoreCase))
        {
            roleText = "Vatandaş";
        }
        else if (role.Equals("Memur", StringComparison.OrdinalIgnoreCase))
        {
            roleText = "Memur";
        }
        else if (role.Equals("Admin", StringComparison.OrdinalIgnoreCase) || role.Equals("Yonetici", StringComparison.OrdinalIgnoreCase))
        {
            roleText = "Yönetici";
        }
        else
        {
            roleText = role;
        }
    }

    var maskedTc = "Kayıtlı değil";
    if (!string.IsNullOrWhiteSpace(tcKimlikNo) && tcKimlikNo.Length >= 11)
    {
        maskedTc = tcKimlikNo.Substring(0, 3) + "*******" + tcKimlikNo.Substring(tcKimlikNo.Length - 2, 2);
    }

    var firstInitial = !string.IsNullOrWhiteSpace(firstName) ? firstName.Substring(0, 1) : "";
    var lastInitial = !string.IsNullOrWhiteSpace(lastName) ? lastName.Substring(0, 1) : "";
    var initials = (firstInitial + lastInitial).ToUpper(new System.Globalization.CultureInfo("tr-TR"));

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "SG";
    }
}

<section class="dashboard-page">
    @await Html.PartialAsync("_CitizenSidebar")

    <main class="dashboard-content">
        <div class="profile-page-header">
            <div>
                <span class="profile-kicker">Hesap Bilgileri</span>
                <h1>Profilim</h1>
                <p>Hesap ve kimlik bilgilerinizi güvenli şekilde görüntüleyebilirsiniz.</p>
            </div>

            <div class="profile-status-badge">
                <span class="status-dot"></span>
                @roleText Hesabı
            </div>
        </div>

        @if (!hasUser)
        {
            <div class="profile-empty-state">
                <div class="empty-icon">ℹ️</div>
                <h2>Kullanıcı bilgileri görüntülenemedi</h2>
                <p>Oturum bilgileri alınamadığı için profil detayları şu anda gösterilemiyor.</p>
                <a href="/Account/Login" class="profile-primary-link">Giriş Sayfasına Dön</a>
            </div>
        }
        else
        {
            <div class="profile-grid">
                <section class="profile-summary-card">
                    <div class="profile-avatar">@initials</div>

                    <div class="profile-summary-info">
                        <h2>@fullName</h2>
                        <p>@roleText</p>
                    </div>

                    <div class="profile-identity-box">
                        <span>T.C. Kimlik No</span>
                        <strong>@maskedTc</strong>
                    </div>

                    <div class="profile-mini-note">
                        Kişisel bilgileriniz güvenlik amacıyla sınırlı ve maskeli şekilde gösterilir.
                    </div>
                </section>

                <section class="profile-info-card">
                    <div class="card-title-row">
                        <div>
                            <h2>Kimlik ve Hesap Bilgileri</h2>
                            <p>Sistemde kayıtlı temel kullanıcı bilgileriniz.</p>
                        </div>
                        <span class="card-icon">🪪</span>
                    </div>

                    <div class="profile-info-list">
                        <div class="profile-info-row">
                            <span>Ad</span>
                            <strong>@displayFirstName</strong>
                        </div>

                        <div class="profile-info-row">
                            <span>Soyad</span>
                            <strong>@displayLastName</strong>
                        </div>

                        <div class="profile-info-row">
                            <span>E-posta</span>
                            <strong>@displayEmail</strong>
                        </div>

                        <div class="profile-info-row">
                            <span>T.C. Kimlik No</span>
                            <strong>@maskedTc</strong>
                        </div>

                        <div class="profile-info-row">
                            <span>Kullanıcı Tipi</span>
                            <strong>@roleText</strong>
                        </div>

                        <div class="profile-info-row">
                            <span>Hesap Durumu</span>
                            <strong class="status-active">Aktif</strong>
                        </div>
                    </div>
                </section>
            </div>

            <div class="profile-section-grid">
                <section class="profile-panel">
                    <div class="card-title-row">
                        <div>
                            <h2>Güvenlik ve Gizlilik</h2>
                            <p>Hassas bilgilerinizin korunmasına yönelik bilgilendirme.</p>
                        </div>
                        <span class="card-icon">🔒</span>
                    </div>

                    <div class="security-list">
                        <div class="security-item">
                            <span class="security-icon">✓</span>
                            <p>T.C. kimlik numaranız güvenlik nedeniyle maskeli gösterilir.</p>
                        </div>

                        <div class="security-item">
                            <span class="security-icon">✓</span>
                            <p>Şifre bilgileriniz hiçbir ekranda görüntülenmez.</p>
                        </div>

                        <div class="security-item">
                            <span class="security-icon">✓</span>
                            <p>Bu sayfa yalnızca hesabınıza ait temel bilgileri görüntüleme amacıyla hazırlanmıştır.</p>
                        </div>
                    </div>
                </section>

                <section class="profile-panel">
                    <div class="card-title-row">
                        <div>
                            <h2>Hızlı İşlemler</h2>
                            <p>Sık kullanılan vatandaş ekranlarına hızlı erişim sağlayabilirsiniz.</p>
                        </div>
                        <span class="card-icon">🧭</span>
                    </div>

                    <div class="quick-action-grid">
                        <a href="/Citizen/PremiumInfo" class="quick-action-card">
                            <span>📊</span>
                            <div>
                                <strong>Prim Bilgilerim</strong>
                                <small>Prim günü ve PEK özeti</small>
                            </div>
                        </a>

                        <a href="/Citizen/RetirementStatus" class="quick-action-card">
                            <span>📘</span>
                            <div>
                                <strong>Emeklilik Durumu</strong>
                                <small>Ön değerlendirme ekranı</small>
                            </div>
                        </a>

                        <a href="/Citizen/DebtOptions" class="quick-action-card">
                            <span>📝</span>
                            <div>
                                <strong>Borçlanma İşlemleri</strong>
                                <small>Doğum, askerlik ve diğer haklar</small>
                            </div>
                        </a>

                        <a href="/Citizen/ServiceMerge" class="quick-action-card">
                            <span>🔗</span>
                            <div>
                                <strong>Hizmet Birleştirme</strong>
                                <small>4A, 4B, 4C statü kontrolü</small>
                            </div>
                        </a>
                    </div>
                </section>
            </div>

            <div class="profile-official-note">
                <div class="note-icon">ℹ️</div>
                <div>
                    <strong>Bilgilendirme Notu</strong>
                    <p>
                        Bu ekran resmi SGK profil ekranı değildir. Sistem, kullanıcı hesabında kayıtlı bilgileri
                        ve yüklenen belgelerden elde edilen ön bilgilendirmeleri gösterir. Kesin işlemler için
                        SGK ve e-Devlet kayıtları esas alınır.
                    </p>
                </div>
            </div>
        }
    </main>
</section>

<style>
    .profile-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 18px;
        margin-bottom: 24px;
        padding: 24px;
        background: linear-gradient(135deg, #ffffff 0%, #f1f7ff 100%);
        border: 1px solid #dbeafe;
        border-radius: 22px;
        box-shadow: 0 14px 35px rgba(15, 23, 42, 0.06);
    }

    .profile-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: #e0f2fe;
        color: #075985;
        font-size: 13px;
        font-weight: 700;
    }

    .profile-page-header h1 {
        margin: 0;
        color: #0f172a;
        font-size: 32px;
        font-weight: 800;
    }

    .profile-page-header p {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 15px;
        max-width: 620px;
        line-height: 1.6;
    }

    .profile-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        padding: 10px 14px;
        border-radius: 999px;
        background: #ecfdf5;
        color: #047857;
        border: 1px solid #bbf7d0;
        font-size: 14px;
        font-weight: 700;
    }

    .status-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: #22c55e;
        box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.16);
    }

    .profile-grid {
        display: grid;
        grid-template-columns: minmax(260px, 0.85fr) minmax(320px, 1.6fr);
        gap: 20px;
        margin-bottom: 20px;
    }

    .profile-summary-card,
    .profile-info-card,
    .profile-panel,
    .profile-empty-state,
    .profile-official-note {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        box-shadow: 0 14px 35px rgba(15, 23, 42, 0.06);
    }

    .profile-summary-card {
        padding: 26px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .profile-avatar {
        width: 86px;
        height: 86px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0f4c81, #1d75b9);
        color: #ffffff;
        font-size: 26px;
        font-weight: 800;
        letter-spacing: 1px;
        box-shadow: 0 18px 34px rgba(15, 76, 129, 0.24);
        margin-bottom: 18px;
    }

    .profile-summary-info h2 {
        margin: 0;
        color: #0f172a;
        font-size: 22px;
        font-weight: 800;
    }

    .profile-summary-info p {
        margin: 6px 0 0;
        color: #2563eb;
        font-weight: 700;
    }

    .profile-identity-box {
        width: 100%;
        margin-top: 22px;
        padding: 16px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
    }

    .profile-identity-box span {
        display: block;
        color: #64748b;
        font-size: 13px;
        margin-bottom: 6px;
    }

    .profile-identity-box strong {
        color: #0f172a;
        font-size: 17px;
        letter-spacing: 0.5px;
    }

    .profile-mini-note {
        margin-top: 16px;
        color: #64748b;
        font-size: 13px;
        line-height: 1.5;
    }

    .profile-info-card,
    .profile-panel {
        padding: 24px;
    }

    .card-title-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 18px;
    }

    .card-title-row h2 {
        margin: 0;
        color: #0f172a;
        font-size: 20px;
        font-weight: 800;
    }

    .card-title-row p {
        margin: 6px 0 0;
        color: #64748b;
        line-height: 1.5;
        font-size: 14px;
    }

    .card-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 20px;
        flex-shrink: 0;
    }

    .profile-info-list {
        display: grid;
        gap: 10px;
    }

    .profile-info-row {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        padding: 14px 16px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
    }

    .profile-info-row span {
        color: #64748b;
        font-size: 14px;
    }

    .profile-info-row strong {
        color: #0f172a;
        font-size: 14px;
        text-align: right;
        word-break: break-word;
    }

    .status-active {
        color: #047857 !important;
    }

    .profile-section-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .security-list {
        display: grid;
        gap: 12px;
    }

    .security-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px;
        border-radius: 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    .security-item p {
        margin: 0;
        color: #334155;
        font-size: 14px;
        line-height: 1.5;
    }

    .security-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #dcfce7;
        color: #15803d;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 800;
        flex-shrink: 0;
    }

    .quick-action-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .quick-action-card {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        text-decoration: none;
        transition: 0.2s ease;
    }

    .quick-action-card:hover {
        background: #eff6ff;
        border-color: #bfdbfe;
        transform: translateY(-2px);
    }

    .quick-action-card > span {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #e0f2fe;
        font-size: 20px;
        flex-shrink: 0;
    }

    .quick-action-card strong {
        display: block;
        color: #0f172a;
        font-size: 15px;
        margin-bottom: 3px;
    }

    .quick-action-card small {
        color: #64748b;
        font-size: 13px;
    }

    .profile-official-note {
        display: flex;
        gap: 14px;
        padding: 18px 20px;
        background: #f8fafc;
    }

    .profile-official-note .note-icon {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        background: #e0f2fe;
        color: #075985;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .profile-official-note strong {
        color: #0f172a;
        font-size: 15px;
    }

    .profile-official-note p {
        margin: 5px 0 0;
        color: #475569;
        line-height: 1.6;
        font-size: 14px;
    }

    .profile-empty-state {
        padding: 36px;
        text-align: center;
    }

    .profile-empty-state .empty-icon {
        font-size: 42px;
        margin-bottom: 12px;
    }

    .profile-empty-state h2 {
        margin: 0;
        color: #0f172a;
        font-size: 22px;
    }

    .profile-empty-state p {
        color: #64748b;
        margin: 10px 0 20px;
    }

    .profile-primary-link {
        display: inline-flex;
        padding: 11px 18px;
        border-radius: 12px;
        background: #0f4c81;
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
    }

    @@media (max-width: 992px) {
        .profile-grid,
        .profile-section-grid {
            grid-template-columns: 1fr;
        }

        .profile-page-header {
            flex-direction: column;
        }

        .profile-status-badge {
            align-self: flex-start;
        }
    }

    @@media (max-width: 640px) {
        .profile-page-header,
        .profile-info-card,
        .profile-panel,
        .profile-summary-card {
            padding: 18px;
            border-radius: 18px;
        }

        .profile-page-header h1 {
            font-size: 26px;
        }

        .profile-info-row {
            flex-direction: column;
            gap: 6px;
        }

        .profile-info-row strong {
            text-align: left;
        }

        .profile-official-note {
            flex-direction: column;
        }
    }
</style>