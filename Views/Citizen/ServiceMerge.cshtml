<script>
(function () {
    window.runServiceMergeAssistant = function () {
        var a = parseFloat(document.getElementById('sm7-4a').value);
        var b = parseFloat(document.getElementById('sm7-4b').value);
        var c = parseFloat(document.getElementById('sm7-4c').value);
        var g = parseFloat(document.getElementById('sm7-gm20').value);
        a = isNaN(a) ? 0 : a;
        b = isNaN(b) ? 0 : b;
        c = isNaN(c) ? 0 : c;
        g = isNaN(g) ? 0 : g;

        var sonStatu  = document.getElementById('sm7-son-statu').value;
        var warnEl    = document.getElementById('sm7-uyari');
        var resultBox = document.getElementById('sm7-result');

        warnEl.textContent = '';

        if (a < 0 || b < 0 || c < 0 || g < 0) {
            warnEl.textContent = 'Gün sayıları negatif olamaz. Lütfen 0 veya üzeri bir değer girin.';
            resultBox.style.display = 'none';
            return;
        }

        var toplam = a + b + c + g;

        if (toplam === 0) {
            warnEl.textContent = 'Son 7 yıl gün bilgisi girilmediği için ön kontrol yapılamadı.';
            resultBox.style.display = 'none';
            return;
        }

        if (toplam > 2520) {
            warnEl.textContent = 'Girilen toplam gün 2520 günü aşıyor. Son 7 yıllık fiili hizmet süresi için toplam gün 2520\'yi geçmemelidir.';
            resultBox.style.display = 'none';
            return;
        }

        var statuses = [
            { key: '4A',   value: a },
            { key: '4B',   value: b },
            { key: '4C',   value: c },
            { key: 'GM20', value: g }
        ];

        var maxValue = Math.max(a, b, c, g);
        var topStatuses = statuses.filter(function (s) { return s.value === maxValue && maxValue > 0; });

        var sonucText, sonucNot;

        if (topStatuses.length > 1) {
            // Eşitlik durumu
            sonucText = 'Girilen günlerde eşitlik görünüyor.';
            sonucNot  = 'Bu durumda son çalışılan statü bilgisi önem kazanabilir. Kesin değerlendirme SGK tarafından yapılır.';
            if (sonStatu) {
                sonucNot += ' Son çalışılan statü olarak ' + sonStatu + ' seçildiği için bu bilgi değerlendirmede dikkate alınabilir; ancak bu resmi sonuç değildir.';
            }
        } else if (maxValue >= 1261) {
            sonucText = 'Girilen bilgilere göre son 7 yıllık fiili hizmet süresinde ağırlıklı statü ' + topStatuses[0].key + ' görünüyor.';
            sonucNot  = 'Bu durum halk arasında 1261 gün kuralı olarak bilinen ön değerlendirme mantığıyla yorumlanmıştır. Kesin statü kararı SGK tarafından verilir.';
        } else {
            sonucText = 'Girilen bilgiler son 7 yıllık dönemi tam karşılamıyor olabilir.';
            sonucNot  = 'Bu nedenle 1261 gün açısından kesin bir ağırlıklı statü yorumu yapılamaz.';
        }

        document.getElementById('sm7-toplam').textContent = toplam.toLocaleString('tr-TR') + ' gün';

        if (topStatuses.length === 1) {
            document.getElementById('sm7-enyuksek').textContent =
                topStatuses[0].key + ' — ' + maxValue.toLocaleString('tr-TR') + ' gün';
        } else if (topStatuses.length > 1) {
            document.getElementById('sm7-enyuksek').textContent =
                topStatuses.map(function (s) { return s.key; }).join(' / ') +
                ' — ' + maxValue.toLocaleString('tr-TR') + ' gün (eşit)';
        } else {
            document.getElementById('sm7-enyuksek').textContent = '—';
        }

        document.getElementById('sm7-sonuc').textContent = sonucText;
        document.getElementById('sm7-sonuc-not').textContent = sonucNot;

        resultBox.style.display = '';
        resultBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };
})();
</script>