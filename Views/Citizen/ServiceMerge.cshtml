@model EmekliRehberi.ViewModels.ServiceMergeInputViewModel
@using EmekliRehberi.Models
@using EmekliRehberi.Services
@using System.Linq

@{
    ViewData["Title"] = "Hizmet Birleştirme";
    ViewData["ActivePage"] = "ServiceMerge";

    var premium = ViewBag.LatestPremium as PremiumDocument;
    var socialSec = ViewBag.LatestSocialSecurity as SocialSecurityRecordDocument;
    var result = ViewBag.Result as ServiceMergeResult;

    string BadgeColor(DataSufficiencyLevel level) => level switch
    {
        DataSufficiencyLevel.Yeterli => "#15803d",
        DataSufficiencyLevel.Sinirli => "#b45309",
        _ => "#b91c1c"
    };

    string BadgeBg(DataSufficiencyLevel level) => level switch
    {
        DataSufficiencyLevel.Yeterli => "#f0fdf4",
        DataSufficiencyLevel.Sinirli => "#fffbeb",
        _ => "#fef2f2"
    };

    string TypeColor(ServiceMergeCommentType type) => type switch
    {
        ServiceMergeCommentType.Success => "#15803d",
        ServiceMergeCommentType.Warning => "#b45309",
        _ => "#004B93"
    };
}

<section class="dashboard-page">
    @await Html.PartialAsync("_CitizenSidebar")

    <main class="dashboard-content">

        <div class="page-title">
            <h1>Hizmet Birleştirme</h1>
            <p>
                Farklı sigorta statülerinde (4A, 4B, 4C) hizmetiniz olup olmadığını ve bunun
                emeklilik sürecinize olası etkisini mevcut belgeleriniz üzerinden gösterir.
            </p>
        </div>

        @* ── Hizmet Birleştirme Nedir? bilgi kartları ─────────────────── *@
        <section class="sm-section">
            <div class="sm-section-header">
                <span class="sm-section-icon">📘</span>
                <h2>Hizmet Birleştirme Nedir?</h2>
            </div>

            <div class="sm-info-grid">
                <details class="sm-info-card">
                    <summary class="sm-info-summary">
                        <span class="sm-info-icon">🔗</span>
                        <span class="sm-info-text">
                            <span class="sm-info-title">Hizmet Birleştirme Nedir?</span>
                            <span class="sm-info-short">Farklı sigorta statülerinde geçen hizmetlerin emeklilik işlemleri öncesinde birlikte değerlendirilmesi sürecidir.</span>
                        </span>
                        <span class="sm-info-chevron">▾</span>
                    </summary>
                    <div class="sm-info-detail">
                        <p>Çalışma hayatı boyunca 4A, 4B, 4C veya geçici 20. madde sandığı kapsamında hizmeti olan kişilerde, bu sürelerin emeklilik hesabında doğru görünmesi önemlidir. Bu ekran, yüklenen belgelerde farklı statü olup olmadığını ön değerlendirme olarak gösterir.</p>
                    </div>
                </details>

                <details class="sm-info-card">
                    <summary class="sm-info-summary">
                        <span class="sm-info-icon">👥</span>
                        <span class="sm-info-text">
                            <span class="sm-info-title">Kimler İçin Gerekli Olabilir?</span>
                            <span class="sm-info-short">Hem işçi, hem Bağ-Kur'lu, hem de kamu görevlisi olarak çalışmış kişiler için önemli olabilir.</span>
                        </span>
                        <span class="sm-info-chevron">▾</span>
                    </summary>
                    <div class="sm-info-detail">
                        <p>Çalışma hayatında yalnızca tek statü varsa hizmet birleştirme ihtiyacı görünmeyebilir. Ancak 4A, 4B, 4C veya sandık hizmetleri birlikte bulunuyorsa, emeklilik öncesinde resmi başvuru ve kayıt kontrolü gerekebilir.</p>
                    </div>
                </details>

                <details class="sm-info-card">
                    <summary class="sm-info-summary">
                        <span class="sm-info-icon">⏰</span>
                        <span class="sm-info-text">
                            <span class="sm-info-title">Ne Zaman Başvurulmalı?</span>
                            <span class="sm-info-short">Emeklilik başvurusundan önce hizmetlerin kontrol edilmesi süreci hızlandırabilir.</span>
                        </span>
                        <span class="sm-info-chevron">▾</span>
                    </summary>
                    <div class="sm-info-detail">
                        <p>Hizmet birleştirme ve kurumlar arası yazışmalar zaman alabilir. Bu nedenle emekliliğe yaklaşmadan önce hizmet dökümü ve sosyal güvenlik kayıt belgesinin kontrol edilmesi faydalıdır. Kesin süre ve işlem gerekliliği SGK tarafından belirlenir.</p>
                    </div>
                </details>

            </div>
        </section>

        @* ── Veri kaynakları kartı ─────────────────────────────────── *@
        <div class="premium-detail-card" style="margin-bottom:18px;">
            <h2>Kullanılan Veri Kaynakları</h2>
            <div class="veri-kaynak-grid">
                <div class="veri-kaynak-item @(premium != null ? "kaynak-var" : "kaynak-yok")">
                    <div class="kaynak-baslik">SGK Tescil ve Hizmet Dökümü</div>
                    <div class="kaynak-durum">
                        @if (premium != null)
                        {
                            <span style="color:#15803d;">&#10003; Yüklendi — @premium.CreatedAt.ToString("dd.MM.yyyy")</span>
                        }
                        else
                        {
                            <span style="color:#b45309;">&#9888; Yüklenmedi</span>
                            <a href="/Citizen/PremiumInfo" style="display:block;margin-top:6px;color:#005BAC;font-weight:700;font-size:13px;">
                                Prim Bilgilerim sayfasından yükleyin
                            </a>
                        }
                    </div>
                </div>
                <div class="veri-kaynak-item @(socialSec != null ? "kaynak-var" : "kaynak-yok")">
                    <div class="kaynak-baslik">Sosyal Güvenlik Kayıt Belgesi</div>
                    <div class="kaynak-durum">
                        @if (socialSec != null)
                        {
                            <span style="color:#15803d;">&#10003; Yüklendi — @socialSec.CreatedAt.ToString("dd.MM.yyyy")</span>
                        }
                        else
                        {
                            <span style="color:#b45309;">&#9888; Henüz yüklenmedi</span>
                            <a href="/Citizen/RetirementStatus" style="display:block;margin-top:6px;color:#005BAC;font-weight:700;font-size:13px;">
                                Emeklilik Durumu sayfasından yükleyin
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (result != null)
        {
            @* ── Sizin Durumunuz (ana kart) ───────────────────────── *@
            <div class="premium-detail-card sizin-durumunuz-card">
                <div class="sufficiency-badge" style="background:@(BadgeBg(result.DataSufficiency));color:@(BadgeColor(result.DataSufficiency));">
                    @result.DataSufficiencyLabel
                </div>
                <h2 style="margin-top:10px;">Sizin Durumunuz</h2>
                <p class="sizin-durumunuz-text">@result.YourSituationSummary</p>

                @if (result.HasSocialSecurityDocument)
                {
                    <div class="mini-stat-grid">
                        <div class="mini-stat">
                            <span>4A</span>
                            <strong>@(result.Days4A?.ToString() ?? "—")</strong>
                        </div>
                        <div class="mini-stat">
                            <span>4B</span>
                            <strong>@(result.Days4B?.ToString() ?? "—")</strong>
                        </div>
                        <div class="mini-stat">
                            <span>4C</span>
                            <strong>@(result.Days4C?.ToString() ?? "—")</strong>
                        </div>
                        <div class="mini-stat">
                            <span>GM20</span>
                            <strong>@(result.DaysGM20?.ToString() ?? "—")</strong>
                        </div>
                        <div class="mini-stat">
                            <span>Toplam</span>
                            <strong>@(result.EffectiveTotalDays > 0 ? result.EffectiveTotalDays.ToString() : "—")</strong>
                        </div>
                    </div>
                }
            </div>

            @* ── Statü bazında gün dağılımı (sadece gerçek dağılım varsa bar göster) ─ *@
            @if (result.HasSocialSecurityDocument)
            {
                <div class="premium-detail-card" style="margin-top:18px;">
                    <h2>Statü Bazında Gün Dağılımı</h2>

                    @if (result.ActiveBranches.Count == 0)
                    {
                        <p style="color:#6b7280;font-size:14px;margin:0;">
                            Belirgin bir statü dağılımı tespit edilemedi. Sosyal Güvenlik Kayıt
                            Belgenizin güncel olduğundan emin olun.
                        </p>
                    }
                    else
                    {
                        var maxDay = new[] { result.Days4A ?? 0, result.Days4B ?? 0, result.Days4C ?? 0 }.Max();

                        <div class="hizmet-bar-grid">
                            @if ((result.Days4A ?? 0) > 0)
                            {
                                var w = maxDay > 0 ? (int)((double)result.Days4A!.Value * 100 / maxDay) : 0;
                                <div class="hizmet-bar-row">
                                    <span class="hizmet-bar-label">4A</span>
                                    <div class="hizmet-bar-track">
                                        <div class="hizmet-bar-fill bar-4a" style="width:@(w)%;"></div>
                                    </div>
                                    <span class="hizmet-bar-value">@result.Days4A gün</span>
                                </div>
                            }
                            @if ((result.Days4B ?? 0) > 0)
                            {
                                var w = maxDay > 0 ? (int)((double)result.Days4B!.Value * 100 / maxDay) : 0;
                                <div class="hizmet-bar-row">
                                    <span class="hizmet-bar-label">4B</span>
                                    <div class="hizmet-bar-track">
                                        <div class="hizmet-bar-fill bar-4b" style="width:@(w)%;"></div>
                                    </div>
                                    <span class="hizmet-bar-value">@result.Days4B gün</span>
                                </div>
                            }
                            @if ((result.Days4C ?? 0) > 0)
                            {
                                var w = maxDay > 0 ? (int)((double)result.Days4C!.Value * 100 / maxDay) : 0;
                                <div class="hizmet-bar-row">
                                    <span class="hizmet-bar-label">4C</span>
                                    <div class="hizmet-bar-track">
                                        <div class="hizmet-bar-fill bar-4c" style="width:@(w)%;"></div>
                                    </div>
                                    <span class="hizmet-bar-value">@result.Days4C gün</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @* ── Değerlendirme (soru-cevap ve diğer gözlemler) ──────────────────── *@
            <div class="premium-detail-card" style="margin-top:18px;">
                <h2>Değerlendirme</h2>
                <div class="qa-list">
                    @foreach (var item in result.AnalysisItems)
                    {
                        <div class="qa-row">
                            <div class="qa-question">@item.Question</div>
                            <div class="qa-answer" style="color:@(TypeColor(item.Type));">@item.Answer</div>
                        </div>
                    }

                    @{
                        var visibleNotes = result.AdditionalNotes
                            .Where(n => n.Title != "Hedef Statü Karşılaştırması")
                            .ToList();
                    }

                    @if (visibleNotes.Any())
                    {
                        <div class="qa-section-title">Diğer Gözlemler</div>

                        @foreach (var note in visibleNotes)
                        {
                            <div class="qa-row">
                                <div class="qa-question" style="color:@(TypeColor(note.Type));">@note.Title</div>
                                <div class="qa-answer">@note.Text</div>
                            </div>
                        }
                    }
                </div>
            </div>

            @* ── 1261 Gün / Son 7 Yıl Bilgi Kutusu ────────────────── *@
            <div class="premium-detail-card sm-rule-box" style="margin-top:18px;">
                <h2>1261 Gün / Son 7 Yıl Kuralı Hakkında</h2>
                <p style="color:#374151;font-size:14px;line-height:1.8;margin:8px 0;">
                    Birden fazla statüde hizmeti olan kişilerde, özellikle 01.10.2008 öncesi sigortalılık
                    geçmişi bulunanlarda, emeklilik statüsünün belirlenmesinde son 7 yıllık fiili hizmet
                    süresi içindeki ağırlıklı statü önem taşıyabilir. Halk arasında bu durum
                    <strong>1261 gün kuralı</strong> olarak bilinir.
                </p>
                <p style="color:#9ca3af;font-size:12px;line-height:1.7;margin:0 0 14px;">
                    Bu ekran son 2520 günlük dönemi dönemsel olarak kesin hesaplamaz. Yüklenen belgeler
                    üzerinden yalnızca statü dağılımı ve farklı statü riski hakkında ön bilgi verir.
                    Kesin statü değerlendirmesi SGK tarafından yapılır.
                </p>

                @if (result.IsMixedService)
                {
                    <div class="sm-rule-note sm-rule-note--warn">
                        ⚠️ Farklı statülerde hizmet göründüğü için son 7 yıl / 1261 gün kuralı açısından
                        SGK resmi kayıtlarıyla ayrıca kontrol yapılması önerilir.
                    </div>
                }
                else
                {
                    <div class="sm-rule-note sm-rule-note--ok">
                        ✅ Mevcut belgelerde farklı statü görünmediği için 1261 gün açısından özel bir
                        risk bu aşamada görünmemektedir.
                    </div>
                }
            </div>
        }

        @* ── Son 7 Yıl / 1261 Gün Ön Kontrol Asistanı ──────────────── *@
        <section class="sm-section" style="margin-top:18px;">
            <div class="sm-section-header">
                <span class="sm-section-icon">🧮</span>
                <h2>Son 7 Yıl / 1261 Gün Ön Kontrol Asistanı</h2>
            </div>

            @if (result != null)
            {
                int positiveStatusCount = new[] { result.Days4A ?? 0, result.Days4B ?? 0, result.Days4C ?? 0, result.DaysGM20 ?? 0 }.Count(d => d > 0);

                if (positiveStatusCount == 1)
                {
                    <div class="sm-rule-note sm-rule-note--ok" style="margin-bottom:14px;">
                        Mevcut belgelerinizde tek statü görünüyor. Bu asistan daha çok birden fazla statüde
                        hizmeti olan kullanıcılar için faydalıdır.
                    </div>
                }
                else if (positiveStatusCount >= 2)
                {
                    <div class="sm-rule-note sm-rule-note--warn" style="margin-bottom:14px;">
                        Belgelerinizde birden fazla statü göründüğü için son 7 yıl / 1261 gün ön kontrolü
                        faydalı olabilir.
                    </div>
                }
            }

            <p style="color:#6b7280;font-size:14px;line-height:1.7;margin:0 0 6px;">
                Son 7 yıllık fiili hizmet süresindeki statü dağılımınızı biliyorsanız, aşağıdaki alanlara
                manuel girerek hangi statünün ağırlıklı göründüğünü kontrol edebilirsiniz.
            </p>
            <p style="color:#9ca3af;font-size:12px;line-height:1.6;margin:0 0 16px;">
                Bu alanı doldurmak zorunlu değildir. Son 7 yıldaki statü günlerinizi bilmiyorsanız resmi
                hizmet dökümünüzü ve SGK kayıtlarınızı kontrol edebilirsiniz.
            </p>

            <div class="sm-assistant-form">
                <div class="sm-assistant-grid">
                    <div class="form-group">
                        <label for="sm7-4a">Son 7 Yıldaki 4A Gün Sayısı</label>
                        <input type="number" id="sm7-4a" class="form-input form-input-sm" min="0" placeholder="0" />
                    </div>
                    <div class="form-group">
                        <label for="sm7-4b">Son 7 Yıldaki 4B Gün Sayısı</label>
                        <input type="number" id="sm7-4b" class="form-input form-input-sm" min="0" placeholder="0" />
                    </div>
                    <div class="form-group">
                        <label for="sm7-4c">Son 7 Yıldaki 4C Gün Sayısı</label>
                        <input type="number" id="sm7-4c" class="form-input form-input-sm" min="0" placeholder="0" />
                    </div>
                    <div class="form-group">
                        <label for="sm7-gm20">Son 7 Yıldaki GM20 / Sandık Gün Sayısı</label>
                        <input type="number" id="sm7-gm20" class="form-input form-input-sm" min="0" placeholder="0" />
                    </div>
                </div>
                <div class="sm-assistant-bottom-row">
                    <div class="form-group" style="max-width:200px;">
                        <label for="sm7-son-statu">Son Çalışılan Statü</label>
                        <select id="sm7-son-statu" class="form-input form-input-sm">
                            <option value="">Bilmiyorum</option>
                            <option value="4A">4A</option>
                            <option value="4B">4B</option>
                            <option value="4C">4C</option>
                            <option value="GM20">GM20</option>
                        </select>
                    </div>
                    <button type="button" class="btn-sm-primary" onclick="runServiceMergeAssistant()">Ön Kontrol Yap</button>
                </div>
                <div class="sm-form-warning" id="sm7-uyari"></div>
            </div>

            <div class="sm-assistant-result" id="sm7-result" style="display:none;">
                <div class="sm-tools-grid" style="grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));">
                    <div class="analysis-card">
                        <div class="ac-icon">📊</div>
                        <div class="ac-title">Girilen Toplam Gün</div>
                        <div class="ac-value" id="sm7-toplam">—</div>
                    </div>
                    <div class="analysis-card">
                        <div class="ac-icon">🏷️</div>
                        <div class="ac-title">En Yüksek Statü</div>
                        <div class="ac-value" id="sm7-enyuksek" style="font-size:17px;">—</div>
                    </div>
                    <div class="analysis-card">
                        <div class="ac-icon">🧭</div>
                        <div class="ac-title">1261 Gün Ön Kontrolü</div>
                        <div class="ac-value" id="sm7-sonuc" style="font-size:13px;font-weight:600;line-height:1.4;">—</div>
                        <div class="ac-note" id="sm7-sonuc-not"></div>
                    </div>
                    <div class="analysis-card analysis-card--warn">
                        <div class="ac-icon">⚠️</div>
                        <div class="ac-title">Dikkat / Resmi Uyarı</div>
                        <div class="ac-note">
                            Bu asistan yalnızca manuel girilen bilgilere göre ön kontrol yapar. Son 2520
                            günlük dönem, hizmet türleri ve resmi statü kararı SGK kayıtlarına göre belirlenir.
                        </div>
                    </div>
                </div>
            </div>
        </section>

        @* ── Resmi Başvuru ve Takip Adımları ───────────────────────── *@
        <section class="sm-section" style="margin-top:18px;">
            <div class="sm-section-header">
                <span class="sm-section-icon">🧭</span>
                <h2>Resmi Başvuru ve Takip Adımları</h2>
            </div>
            <p style="color:#6b7280;font-size:13px;margin:0 0 16px;">
                Hizmetlerinizi kontrol ettikten sonra resmi başvuru ve takip işlemleri için
                e-Devlet/SGK ekranlarını kullanabilirsiniz.
            </p>

            <div class="sm-tools-grid">
                <a href="https://www.turkiye.gov.tr/sgk-tescil-ve-hizmet-dokumu" target="_blank" rel="noopener noreferrer" class="sm-tool-card">
                    <div class="sm-tool-icon">📄</div>
                    <div class="sm-tool-title">Hizmetlerinizi Kontrol Edin</div>
                    <div class="sm-tool-desc">Emekliliğe esas uzun vade hizmetlerinizi ve işyeri ünvan listesini e-Devlet üzerinden görüntüleyebilirsiniz.</div>
                    <div class="sm-tool-btn">e-Devlet'te Aç →</div>
                </a>

                <a href="https://www.turkiye.gov.tr/sosyal-guvenlik-kayit-belgesi-sorgulama" target="_blank" rel="noopener noreferrer" class="sm-tool-card">
                    <div class="sm-tool-icon">🪪</div>
                    <div class="sm-tool-title">Sigorta Kayıt Belgenizi Alın</div>
                    <div class="sm-tool-desc">4A, 4B ve 4C sigorta kayıt bilgilerinizi içeren barkodlu belgeyi e-Devlet üzerinden alabilirsiniz.</div>
                    <div class="sm-tool-btn">e-Devlet'te Aç →</div>
                </a>

                <a href="https://www.turkiye.gov.tr/sosyal-guvenlik-41-a-b-ve-506-sk-gm-20-nci-madde-sandigi-calisanlarin-hizmet-birlestirme-basvurusu" target="_blank" rel="noopener noreferrer" class="sm-tool-card">
                    <div class="sm-tool-icon">📝</div>
                    <div class="sm-tool-title">Hizmet Birleştirme Başvurusu Yapın</div>
                    <div class="sm-tool-desc">4/1-a, 4/1-b ve 506 SK geçici 20. madde sandığı kapsamındaki hizmetler için resmi başvuru ekranıdır.</div>
                    <div class="sm-tool-btn">Başvuruya Git →</div>
                </a>

                <a href="https://www.turkiye.gov.tr/sgk-sso-evrak-takip" target="_blank" rel="noopener noreferrer" class="sm-tool-card">
                    <div class="sm-tool-icon">📬</div>
                    <div class="sm-tool-title">Başvurunuzu Takip Edin</div>
                    <div class="sm-tool-desc">SGK'ya iletilen başvuru ve evrak süreçlerini DYS Evrak Takip üzerinden kontrol edebilirsiniz.</div>
                    <div class="sm-tool-btn">Evrak Takip →</div>
                </a>
            </div>
        </section>

        @if (result != null)
        {
            @* ── Tamamlanması önerilen bilgiler ───────────────────── *@
            @if (result.MissingDataNotices.Any())
            {
                <div class="premium-detail-card" style="margin-top:18px;">
                    <h2>Tamamlanması Önerilen Bilgiler</h2>
                    <div class="checklist">
                        @foreach (var notice in result.MissingDataNotices)
                        {
                            <div class="checklist-item check-missing">
                                <span class="check-icon">○</span>
                                <span>@notice</span>
                            </div>
                        }
                    </div>
                </div>
            }
        }

    </main>
</section>

<style>
    .veri-kaynak-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .veri-kaynak-item {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 16px 18px;
        background: #f9fafb;
    }

    .kaynak-var { border-left: 4px solid #15803d; }
    .kaynak-yok { border-left: 4px solid #b45309; }

    .kaynak-baslik {
        font-weight: 700;
        color: #111827;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .kaynak-durum { font-size: 13px; }

    .sizin-durumunuz-card {
        border-left: 5px solid #005BAC;
    }

    .sufficiency-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .sizin-durumunuz-text {
        color: #374151;
        line-height: 1.8;
        font-size: 15px;
        margin: 8px 0 18px;
    }

    .mini-stat-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .mini-stat {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 10px;
        text-align: center;
    }

    .mini-stat span {
