@{
    ViewData["Title"] = "Başvuru Rehberi";
}

<section class="dashboard-page">
    <aside class="sidebar">
        <div class="sidebar-title">Hizmetler</div>

        <a href="/Citizen">Ana Sayfa</a>
        <a href="/Citizen/ServiceStatement">Hizmet Dökümü</a>
        <a href="/Citizen/PremiumInfo">Prim Bilgilerim</a>
        <a href="/Citizen/RetirementStatus">Emeklilik Durumu</a>
        <a href="/Citizen/DebtOptions">Borçlanma İşlemleri</a>
        <a href="/Citizen/ServiceMerge">Hizmet Birleştirme</a>
        <a class="active" href="/Citizen/ApplicationGuide">Başvuru Rehberi</a>
        <a href="/Citizen/RecentActions">Son İşlemler</a>
        <a href="/Citizen/Profile">Profilim</a>
    </aside>

    <main class="dashboard-content">
        <div class="page-title">
            <h1>Başvuru Rehberi</h1>
            <p>
                Emeklilik ve ilgili işlemler için başvuru öncesinde kontrol edilmesi gereken adımları inceleyebilirsiniz.
            </p>
        </div>

        <div class="service-dashboard-grid">
            <div class="service-tile">
                <h3>Emeklilik Başvurusu</h3>
                <p>Başvuru öncesinde hizmet dökümü, prim günü ve kimlik bilgilerinin kontrol edilmesi önerilir.</p>
            </div>

            <div class="service-tile">
                <h3>Borçlanma Başvurusu</h3>
                <p>Doğum, askerlik veya diğer borçlanma türleri için başvuru öncesi genel bilgilendirme.</p>
            </div>

            <div class="service-tile">
                <h3>Hizmet Birleştirme</h3>
                <p>Farklı sigorta statülerinde çalışma varsa süreç hakkında bilgilendirme.</p>
            </div>

            <div class="service-tile">
                <h3>Malulen Emeklilik</h3>
                <p>Sağlık kurulu raporu ve ilgili şartlar hakkında genel rehberlik.</p>
            </div>

            <div class="service-tile">
                <h3>Dul ve Yetim Aylığı</h3>
                <p>Hak sahipliği ve başvuru sürecine ilişkin temel açıklamalar.</p>
            </div>

            <div class="service-tile">
                <h3>Belge Doğrulama</h3>
                <p>e-Devlet üzerinden alınan belgelerin doğrulanması hakkında bilgilendirme.</p>
            </div>
        </div>

        <div class="guidance-card">
            <h2>Genel Başvuru Adımları</h2>
            <ul>
                <li>Hizmet dökümünüzü kontrol edin.</li>
                <li>Prim günlerinizi ve sigorta başlangıcınızı inceleyin.</li>
                <li>Eksik ya da hatalı bilgi olduğunu düşünüyorsanız ilgili kuruma başvurun.</li>
                <li>Başvuru türüne göre gerekli belgeleri hazırlayın.</li>
                <li>e-Devlet veya SGK kanalları üzerinden işlemi başlatın.</li>
            </ul>
        </div>
    </main>
</section>